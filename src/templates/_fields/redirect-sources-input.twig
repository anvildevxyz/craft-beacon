{# values: list<string>, name: string, id: string #}
<div class="beacon-redirect-sources" id="{{ id }}-wrap" data-field-name="{{ name }}">
    <div class="beacon-redirect-sources__list" id="{{ id }}-list">
        {% for uri in values %}
            <div class="beacon-redirect-sources__row">
                <input type="text"
                       name="{{ name }}[]"
                       value="{{ uri }}"
                       class="text fullwidth"
                       placeholder="{{ '/old/path'|t('beacon') }}"
                       autocomplete="off">
                <button type="button" class="btn small beacon-redirect-sources__remove" aria-label="{{ 'Remove'|t('beacon') }}">×</button>
            </div>
        {% endfor %}
    </div>
    {# Always emit at least one empty input so the field POSTs `name[]=` even when empty,
       so afterElementSave receives an array (not null) and can detect "all removed". #}
    {% if values is empty %}
        <input type="hidden" name="{{ name }}[]" value="">
    {% endif %}
    <button type="button" class="btn add icon beacon-redirect-sources__add" id="{{ id }}-add">
        {{ 'Add legacy URL'|t('beacon') }}
    </button>
    <p class="light"><small>{{ 'Each URI 301-redirects to this entry. Use a leading slash, e.g. /old-news/foo.'|t('beacon') }}</small></p>
</div>
