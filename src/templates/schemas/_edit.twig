{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'schemas' %}
{% import '_includes/forms.twig' as forms %}
{% set title = schema.id ? ('schemas.edit.edit.schema.text'|t('beacon')) : ('schemas.edit.new.schema.text'|t('beacon')) %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'nav.schemas'|t('beacon'), url: cpUrl('beacon/schemas') },
] %}

{% set formActions = [{
    label: 'schemas.edit.save.continue.editing.label'|t('beacon'),
    redirect: 'beacon/schemas/{id}'|hash,
    shortcut: true,
    retainScroll: true,
}] %}

{# Build the dropdown from SchemaService::registeredTypes() so adding a type
   in Plugin.php (or via the `config/beacon.php` `schemaTypes` extension)
   automatically shows up here — no twig edit needed. #}
{% set schemaTypeOptions = {} %}
{% for type in schemaTypes %}
    {% set schemaTypeOptions = schemaTypeOptions|merge({ (type): type }) %}
{% endfor %}

{% block content %}
    <input type="hidden" name="action" value="beacon/schemas/save">
    <input type="hidden" name="schemaId" value="{{ schema.id }}">
    {{ redirectInput('beacon/schemas') }}
    {{ csrfInput() }}

    <h2 class="heading first">{{ 'schemas.edit.match.heading'|t('beacon') }}</h2>
    <p class="light">{{ 'schemas.edit.pick.entry.type.schema.applies.text'|t('beacon') }}</p>

    {{ forms.selectField({
        label: 'schemas.edit.entryTypeHandle.label'|t('beacon'),
        id: 'entryTypeHandle',
        name: 'entryTypeHandle',
        value: schema.entryTypeHandle,
        options: entryTypes,
        required: true,
        first: true,
    }) }}

    <hr>

    <h2>{{ 'schemas.edit.schema.output.heading'|t('beacon') }}</h2>
    <p class="light">{{ 'schemas.edit.choose.schema.org.type.define.text'|t('beacon') }}</p>

    {{ forms.selectField({
        label: 'schemas.edit.schemaType.label'|t('beacon'),
        id: 'schemaType',
        name: 'schemaType',
        value: schema.schemaType,
        options: schemaTypeOptions,
        required: true,
    }) }}

    {# Guided property-mapping builder. Progressive enhancement: the raw JSON
       textarea below is the canonical posted field and works without JS; the
       builder (beacon-cp.js) hides it, renders one input per schema.org property
       from the SchemaPropertyRegistry, and keeps the textarea in sync. #}
    <div class="field">
        <div class="heading">
            <label>{{ 'schemas.edit.property.mapping.text'|t('beacon') }}</label>
        </div>
        <div class="instructions">
            <p>{{ 'schemas.edit.fill.value.each.schema.org.text'|t('beacon') }}</p>
        </div>

        <div id="beacon-schema-builder"
             data-beacon-schema-builder
             data-registry="{{ schemaProperties|json_encode|e('html_attr') }}"
             data-mapping="{{ (schema.mapping ?? '{}')|e('html_attr') }}"
             data-type-select="#schemaType"
             data-entry-type-select="#entryTypeHandle"
             data-suggest-action="{{ suggestUrl }}"
             data-preview-action="{{ previewUrl }}"></div>

        {# Fallback / advanced raw-JSON editor. #}
        {{ forms.textarea({
            name: 'mapping',
            id: 'mapping',
            value: schema.mapping ?? '{}',
            rows: 10,
            class: 'code',
            placeholder: '{}',
        }) }}
        <div class="instructions" data-bsb-raw-help>
            <p>{{ 'schemas.edit.json.object.mapping.each.schema.text'|t('beacon') }}</p>
        </div>
    </div>
{% endblock %}

{% block details %}
    <div class="meta">
        {{ forms.lightswitchField({
            label: 'field.enabled'|t('beacon'),
            id: 'enabled',
            name: 'enabled',
            on: schema.enabled ?? true,
        }) }}
    </div>

    {% if schema.id %}
        <div class="meta read-only">
            <div class="data">
                <h5 class="heading">{{ 'schemas.edit.sort.order.text'|t('beacon') }}</h5>
                <div class="value">{{ schema.sortOrder }}</div>
            </div>
            {% if schema.dateCreated %}
                <div class="data">
                    <h5 class="heading">{{ 'schemas.edit.created.text'|t('beacon') }}</h5>
                    <div class="value">{{ schema.dateCreated|datetime('short') }}</div>
                </div>
            {% endif %}
            {% if schema.dateUpdated %}
                <div class="data">
                    <h5 class="heading">{{ 'schemas.edit.updated.text'|t('beacon') }}</h5>
                    <div class="value">{{ schema.dateUpdated|datetime('short') }}</div>
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
