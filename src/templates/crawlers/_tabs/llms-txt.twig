{% import '_includes/forms.twig' as forms %}

<input type="hidden" name="action" value="beacon/llms-settings/save">
<input type="hidden" name="siteId" value="{{ site.id }}">
{{ redirectInput('beacon/crawlers/llms-txt?site=' ~ site.handle) }}
{{ csrfInput() }}

{% include 'beacon/_includes/site-selector' with { sites, site, baseUrl: cpUrl('beacon/crawlers/llms-txt') } only %}

{{ forms.lightswitchField({
    label: 'field.enabled'|t('beacon'),
    instructions: 'llms.enabled.instructions'|t('beacon'),
    name: 'enabled',
    on: settings.enabled,
    first: true,
}) }}

{{ forms.textField({
    label: 'llms.siteNameOverride.label'|t('beacon'),
    instructions: 'llms.siteNameOverride.instructions'|t('beacon'),
    name: 'siteNameOverride',
    value: settings.siteNameOverride,
    placeholder: site.name,
}) }}

{{ forms.textareaField({
    label: 'llms.summary.label'|t('beacon'),
    instructions: 'llms.summary.instructions'|t('beacon'),
    name: 'summary',
    value: settings.summary,
    rows: 4,
}) }}

{% include 'beacon/crawlers/_fields/sections-editor' with {
    label: 'llms.sections.label'|t('beacon'),
    instructions: 'llms.sections.instructions'|t('beacon'),
    name: 'sections',
    allSections: allSections,
    values: settings.sections,
} only %}

<hr>
<h2>{{ 'llms.trust.block.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'llms.optional.usage.policy.lines.appended.text'|t('beacon') }}</p>

{{ forms.textField({
    label: 'llms.policyUrl.label'|t('beacon'),
    instructions: 'llms.policyUrl.instructions'|t('beacon'),
    name: 'policyUrl',
    value: settings.policyUrl,
    placeholder: 'llms.policyUrl.placeholder'|t('beacon'),
    first: true,
}) }}

{{ forms.textField({
    label: 'llms.licenseUrl.label'|t('beacon'),
    instructions: 'llms.licenseUrl.instructions'|t('beacon'),
    name: 'licenseUrl',
    value: settings.licenseUrl,
    placeholder: 'llms.licenseUrl.placeholder'|t('beacon'),
}) }}

{{ forms.textField({
    label: 'llms.contactEmail.label'|t('beacon'),
    instructions: 'llms.contactEmail.instructions'|t('beacon'),
    name: 'contactEmail',
    type: 'email',
    value: settings.contactEmail,
}) }}

{{ forms.textareaField({
    label: 'llms.preferredAttribution.label'|t('beacon'),
    instructions: 'llms.preferredAttribution.instructions'|t('beacon'),
    name: 'preferredAttribution',
    value: settings.preferredAttribution,
    rows: 3,
}) }}

<hr>
<h2>{{ 'llms.llms.full.txt.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'llms.long.form.companion.llms.txt.text'|t('beacon') }}</p>

<div class="beacon-fullbody-editor">
  <div class="fullbody-helper">
    <label class="helper-label">{{ 'beacon.insert.section.variable'|t('beacon') }}</label>
    <div class="helper-buttons" data-textarea-name="fullBody">
      {% for section in allSections %}
        <button
          type="button"
          class="helper-button"
          data-insert="[{{ section.value }}]"
          title="{{ 'beacon.insert'|t('beacon') }}: {{ section.label }}"
        >
          {{ section.label }}
        </button>
      {% endfor %}
    </div>
  </div>

  {{ forms.textareaField({
      label: 'llms.fullBody.label'|t('beacon'),
      instructions: 'llms.fullBody.instructions'|t('beacon'),
      name: 'fullBody',
      value: settings.fullBody,
      rows: 16,
      class: 'fullwidth code',
  }) }}

  {{ forms.textField({
      label: 'llms.tokenBudget.label'|t('beacon'),
      instructions: 'llms.tokenBudget.instructions'|t('beacon'),
      name: 'llmsFullTokenBudget',
      type: 'number',
      size: 10,
      value: settings.llmsFullTokenBudget,
      placeholder: '0',
  }) }}

  <p class="beacon-token-readout light">
    {{ 'llms.tokenBudget.estimate'|t('beacon') }}:
    <strong data-beacon-token-count>{{ fullBodyTokens|number_format }}</strong>
    <span data-beacon-token-budgetnote>
      {% if settings.llmsFullTokenBudget %}
        / {{ settings.llmsFullTokenBudget|number_format }}
        {% if fullBodyTokens > settings.llmsFullTokenBudget %}
          — <span class="error">{{ 'llms.tokenBudget.overBudget'|t('beacon') }}</span>
        {% endif %}
      {% endif %}
    </span>
  </p>
</div>

<style>
  .beacon-fullbody-editor {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fullbody-helper {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 3px;
    padding: 0.5rem;
  }

  .helper-label {
    display: block;
    font-weight: 600;
    font-size: 0.8rem;
    margin-bottom: 0.4rem;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .helper-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .helper-button {
    padding: 0.35rem 0.6rem;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 3px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .helper-button:hover {
    background: #f3f4f6;
    border-color: #0f7a8f;
    color: #0f7a8f;
  }

  .helper-button:active {
    transform: scale(0.97);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const helperButtons = document.querySelectorAll('.helper-button');
    const textareaName = document.querySelector('.helper-buttons')?.dataset.textareaName;
    const textarea = textareaName ? document.querySelector(`textarea[name="${textareaName}"]`) : null;

    // Live token estimate — mirrors HeuristicTokenEstimator: average of
    // chars/4 and words*1.3. Approximate; the server value is authoritative.
    const fullBody = document.querySelector('textarea[name="fullBody"]');
    const tokenCount = document.querySelector('[data-beacon-token-count]');
    if (fullBody && tokenCount) {
      const estimate = (text) => {
        const t = text.trim();
        if (t === '') return 0;
        const chars = t.length;
        const words = t.split(/\s+/).length;
        return Math.max(1, Math.ceil((chars / 4 + words * 1.3) / 2));
      };
      const update = () => {
        tokenCount.textContent = estimate(fullBody.value).toLocaleString();
      };
      fullBody.addEventListener('input', update);
    }

    if (!textarea) return;

    helperButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const insertText = btn.dataset.insert;

        // Insert at cursor position
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const before = textarea.value.substring(0, start);
        const after = textarea.value.substring(end);
        textarea.value = before + insertText + after;

        // Move cursor after inserted text
        textarea.selectionStart = textarea.selectionEnd = start + insertText.length;
        textarea.focus();

        // Trigger change event for Craft
        textarea.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });
  });
</script>
