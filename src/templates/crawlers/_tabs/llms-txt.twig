{% import '_includes/forms.twig' as forms %}

<input type="hidden" name="action" value="beacon/llms-settings/save">
<input type="hidden" name="siteId" value="{{ site.id }}">
{{ redirectInput('beacon/crawlers/llms-txt?site=' ~ site.handle) }}
{{ csrfInput() }}

{% include 'beacon/_includes/site-selector' with { sites, site, baseUrl: cpUrl('beacon/crawlers/llms-txt') } only %}

{{ forms.lightswitchField({
    label: 'field.enabled'|t('beacon'),
    instructions: 'llms.enabled.instructions'|t('beacon'),
    name: 'enabled',
    on: settings.enabled,
    first: true,
}) }}

{{ forms.textField({
    label: 'llms.siteNameOverride.label'|t('beacon'),
    instructions: 'llms.siteNameOverride.instructions'|t('beacon'),
    name: 'siteNameOverride',
    value: settings.siteNameOverride,
    placeholder: site.name,
}) }}

{{ forms.textareaField({
    label: 'llms.summary.label'|t('beacon'),
    instructions: 'llms.summary.instructions'|t('beacon'),
    name: 'summary',
    value: settings.summary,
    rows: 4,
}) }}

{% include 'beacon/crawlers/_fields/sections-editor' with {
    label: 'llms.sections.label'|t('beacon'),
    instructions: 'llms.sections.instructions'|t('beacon'),
    name: 'sections',
    allSections: allSections,
    values: settings.sections,
} only %}

<hr>
<h2>{{ 'llms.trust.block.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'llms.optional.usage.policy.lines.appended.text'|t('beacon') }}</p>

{{ forms.textField({
    label: 'llms.policyUrl.label'|t('beacon'),
    instructions: 'llms.policyUrl.instructions'|t('beacon'),
    name: 'policyUrl',
    value: settings.policyUrl,
    placeholder: 'llms.policyUrl.placeholder'|t('beacon'),
    first: true,
}) }}

{{ forms.textField({
    label: 'llms.licenseUrl.label'|t('beacon'),
    instructions: 'llms.licenseUrl.instructions'|t('beacon'),
    name: 'licenseUrl',
    value: settings.licenseUrl,
    placeholder: 'llms.licenseUrl.placeholder'|t('beacon'),
}) }}

{{ forms.textField({
    label: 'llms.contactEmail.label'|t('beacon'),
    instructions: 'llms.contactEmail.instructions'|t('beacon'),
    name: 'contactEmail',
    type: 'email',
    value: settings.contactEmail,
}) }}

{{ forms.textareaField({
    label: 'llms.preferredAttribution.label'|t('beacon'),
    instructions: 'llms.preferredAttribution.instructions'|t('beacon'),
    name: 'preferredAttribution',
    value: settings.preferredAttribution,
    rows: 3,
}) }}

<hr>
<h2>{{ 'llms.llms.full.txt.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'llms.long.form.companion.llms.txt.text'|t('beacon') }}</p>

{{ forms.textareaField({
    label: 'llms.fullBody.label'|t('beacon'),
    instructions: 'llms.fullBody.instructions'|t('beacon'),
    name: 'fullBody',
    value: settings.fullBody,
    rows: 16,
    class: 'fullwidth code',
}) }}
