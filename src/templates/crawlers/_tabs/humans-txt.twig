{% import '_includes/forms.twig' as forms %}

<input type="hidden" name="action" value="beacon/humans-settings/save">
<input type="hidden" name="siteId" value="{{ site.id }}">
{{ redirectInput('beacon/crawlers/humans-txt?site=' ~ site.handle) }}
{{ csrfInput() }}

{% include 'beacon/_includes/site-selector' with { sites, site, baseUrl: cpUrl('beacon/crawlers/humans-txt') } only %}

{{ forms.lightswitchField({
    label: 'field.enabled'|t('beacon'),
    instructions: 'humansTxt.enabled.instructions'|t('beacon'),
    name: 'enabled',
    on: settings.enabled,
    first: true,
}) }}

{{ forms.textareaField({
    label: 'humansTxt.body.label'|t('beacon'),
    instructions: 'humansTxt.body.instructions'|t('beacon'),
    name: 'body',
    value: settings.body,
    rows: 16,
    class: 'fontMono',
}) }}
