{% import '_includes/forms.twig' as forms %}

<h2 class="heading first">{{ 'aiCrawlers.rules.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'aiCrawlers.crawler.specific.allow.disallow.paths.text'|t('beacon') }}</p>
<div class="buttons">
    <a href="{{ url('beacon/crawlers/ai-crawlers/rules/new') }}" class="btn submit add icon">{{ 'aiCrawlers.new.rule.text'|t('beacon') }}</a>
</div>

{% if rules is empty %}
    <div class="beacon-empty beacon-space-bottom">
        <div class="beacon-empty__icon" aria-hidden="true">🛡️</div>
        <h3>{{ 'aiCrawlers.no.crawler.rules.yet.heading'|t('beacon') }}</h3>
        <p>{{ 'aiCrawlers.add.allow.disallow.rules.shape.text'|t('beacon') }}</p>
        <div class="beacon-empty__actions">
            <a href="{{ url('beacon/crawlers/ai-crawlers/rules/new') }}" class="btn submit">{{ 'aiCrawlers.create.first.rule.text'|t('beacon') }}</a>
        </div>
    </div>
{% else %}
    <table class="data fullwidth beacon-space-bottom">
        <thead>
            <tr>
                <th>{{ 'aiCrawlers.bot.text'|t('beacon') }}</th>
                <th>{{ 'aiCrawlers.allow.text'|t('beacon') }}</th>
                <th>{{ 'aiCrawlers.disallow.text'|t('beacon') }}</th>
                <th class="thin">{{ 'field.enabled'|t('beacon') }}</th>
                <th class="thin"></th>
            </tr>
        </thead>
        <tbody>
        {% for r in rules %}
            <tr>
                <td><a href="{{ url('beacon/crawlers/ai-crawlers/rules/' ~ r.id) }}">{{ r.botName }}</a></td>
                <td><code>{{ r.allowPaths|join(', ') ?: 'common.emDash'|t('beacon') }}</code></td>
                <td><code>{{ r.disallowPaths|join(', ') ?: 'common.emDash'|t('beacon') }}</code></td>
                <td class="thin">
                    {{ forms.lightswitch({
                        on: r.enabled,
                        small: true,
                        containerAttributes: {
                            data: {
                                'beacon-toggle': 'rule',
                                'beacon-id': r.id,
                            },
                        },
                    }) }}
                </td>
                <td class="thin">
                    <form method="post" action="" class="inline" data-confirm="{{ 'aiCrawlers.delete.rule.text'|t('beacon') }}">
                        {{ csrfInput() }}
                        <input type="hidden" name="action" value="beacon/ai-crawlers/delete-rule">
                        <input type="hidden" name="ruleId" value="{{ r.id }}">
                        <button type="submit" class="delete icon" title="{{ 'action.delete'|t('beacon') }}"></button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

<hr>

<h2>{{ 'aiCrawlers.bots.heading'|t('beacon') }}</h2>
<p class="instructions">{{ 'aiCrawlers.known.ai.crawlers.defaults.custom.text'|t('beacon') }}</p>
<div class="buttons">
    <a href="{{ url('beacon/crawlers/ai-crawlers/bots/new') }}" class="btn submit add icon">{{ 'aiCrawlers.new.bot.text'|t('beacon') }}</a>
    <form method="post" action="" data-confirm="{{ 'aiCrawlers.restore.default.bots.have.been.text'|t('beacon') }}">
        {{ csrfInput() }}
        <input type="hidden" name="action" value="beacon/ai-crawlers/reset-defaults">
        <button type="submit" class="btn">{{ 'aiCrawlers.restore.defaults.text'|t('beacon') }}</button>
    </form>
</div>

<table class="data fullwidth">
    <thead>
        <tr>
            <th>{{ 'aiCrawlers.name.text'|t('beacon') }}</th>
            <th>{{ 'aiCrawlers.user.agent.pattern.text'|t('beacon') }}</th>
            <th class="thin">{{ 'field.enabled'|t('beacon') }}</th>
            <th>{{ 'aiCrawlers.source.text'|t('beacon') }}</th>
            <th class="thin"></th>
        </tr>
    </thead>
    <tbody>
    {% for b in bots %}
        <tr>
            <td><a href="{{ url('beacon/crawlers/ai-crawlers/bots/' ~ b.id) }}">{{ b.name }}</a></td>
            <td><code>{{ b.userAgentPattern }}</code></td>
            <td class="thin">
                {{ forms.lightswitch({
                    on: b.enabled,
                    small: true,
                    containerAttributes: {
                        data: {
                            'beacon-toggle': 'bot',
                            'beacon-id': b.id,
                        },
                    },
                }) }}
            </td>
            <td>
                {% if b.source == 'default' %}
                    <span class="status active"></span> {{ 'aiCrawlers.default.text'|t('beacon') }}
                {% else %}
                    <span class="status"></span> {{ 'aiCrawlers.custom.text'|t('beacon') }}
                {% endif %}
            </td>
            <td class="thin">
                <form method="post" action="" class="inline" data-confirm="{{ b.source == 'default' ? 'aiCrawlers.delete.default.bot.you.can.text'|t('beacon') : 'aiCrawlers.delete.bot.text'|t('beacon') }}">
                    {{ csrfInput() }}
                    <input type="hidden" name="action" value="beacon/ai-crawlers/delete-bot">
                    <input type="hidden" name="botId" value="{{ b.id }}">
                    <button type="submit" class="delete icon" title="{{ 'action.delete'|t('beacon') }}"></button>
                </form>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
