{% import '_includes/forms.twig' as forms %}

<input type="hidden" name="action" value="beacon/robots-settings/save">
<input type="hidden" name="siteId" value="{{ site.id }}">
{{ redirectInput('beacon/crawlers/robots?site=' ~ site.handle) }}
{{ csrfInput() }}

{% include 'beacon/_includes/site-selector' with { sites, site, baseUrl: cpUrl('beacon/crawlers/robots') } only %}

{{ forms.textField({
    label: 'crawlers.robots.sitemapUrl.label'|t('beacon'),
    instructions: 'crawlers.robots.sitemapUrl.instructions'|t('beacon'),
    name: 'sitemapUrl',
    value: settings.sitemapUrl,
    first: true,
}) }}

{{ forms.textareaField({
    label: 'crawlers.robots.userAgentRulesText.label'|t('beacon'),
    instructions: 'crawlers.robots.userAgentRulesText.instructions'|t('beacon'),
    name: 'userAgentRulesText',
    value: userAgentRulesText,
    rows: 12,
    class: 'fontMono',
}) }}
