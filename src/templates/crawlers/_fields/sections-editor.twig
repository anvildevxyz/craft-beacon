<div class="beacon-sections-editor">
  <div class="sections-editor-header">
    <label class="required">{{ label }}</label>
    {% if instructions %}<p class="instructions">{{ instructions }}</p>{% endif %}
  </div>

  <div class="sections-button-bar" data-field-name="{{ name }}">
    {% for section in allSections %}
      <button
        type="button"
        class="section-button {% if section.value in values %}selected{% endif %}"
        data-handle="{{ section.value }}"
        draggable="true"
        title="Click to toggle, drag to reorder"
      >
        {{ section.label }}
      </button>
    {% endfor %}
  </div>

  <p class="sections-hint">{{ 'beacon.drag.to.reorder'|t('beacon') }}</p>

  {# Hidden inputs for form submission #}
  <div class="sections-hidden">
    {% for value in values %}
      <input type="hidden" name="{{ name }}[]" value="{{ value }}">
    {% endfor %}
  </div>
</div>

<style>
  .beacon-sections-editor {
    margin: 1rem 0;
  }

  .sections-editor-header {
    margin-bottom: 0.75rem;
  }

  .sections-editor-header label {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .sections-editor-header .instructions {
    margin: 0;
    font-size: 0.85rem;
    color: #666;
  }

  .sections-button-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    min-height: 40px;
    align-content: flex-start;
  }

  .section-button {
    padding: 0.5rem 1rem;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 20px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
    font-weight: 500;
    color: #374151;
  }

  .section-button:hover {
    border-color: #0f7a8f;
    background: #f0fafb;
    color: #0f7a8f;
  }

  .section-button.selected {
    background: #0f7a8f;
    border-color: #0f7a8f;
    color: white;
    font-weight: 600;
  }

  .section-button.selected:hover {
    background: #0a5a6f;
    border-color: #0a5a6f;
  }

  .section-button.drag-item {
    opacity: 0.6;
  }

  .sections-hint {
    margin: 0.5rem 0 0 0;
    font-size: 0.8rem;
    color: #999;
    font-style: italic;
  }

  .sections-hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bar = document.querySelector('.sections-button-bar');
    if (!bar) return;
    const fieldName = bar.dataset.fieldName;
    const hiddenContainer = document.querySelector('.sections-hidden');
    let draggedElement = null;

    // Toggle selection on click
    bar.querySelectorAll('.section-button').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btn.classList.toggle('selected');
        updateHiddenInputs();
      });
    });

    // Drag and drop
    bar.addEventListener('dragstart', (e) => {
      if (e.target.classList.contains('section-button')) {
        draggedElement = e.target;
        draggedElement.classList.add('drag-item');
        e.dataTransfer.effectAllowed = 'move';
      }
    });

    bar.addEventListener('dragend', (e) => {
      draggedElement?.classList.remove('drag-item');
      draggedElement = null;
    });

    bar.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
    });

    bar.addEventListener('drop', (e) => {
      e.preventDefault();
      if (!draggedElement) return;

      const afterElement = getDragAfterElement(bar, e.clientX);
      if (afterElement == null) {
        bar.appendChild(draggedElement);
      } else {
        bar.insertBefore(draggedElement, afterElement);
      }

      updateHiddenInputs();
    });

    function getDragAfterElement(container, x) {
      const draggableElements = [...container.querySelectorAll('.section-button:not(.drag-item)')];

      return draggableElements.reduce(
        (closest, child) => {
          const box = child.getBoundingClientRect();
          const offset = x - box.left - box.width / 2;

          if (offset < 0 && offset > closest.offset) {
            return { offset: offset, element: child };
          } else {
            return closest;
          }
        },
        { offset: Number.NEGATIVE_INFINITY }
      ).element;
    }

    function updateHiddenInputs() {
      hiddenContainer.innerHTML = '';
      bar.querySelectorAll('.section-button.selected').forEach((btn) => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = fieldName + '[]';
        input.value = btn.dataset.handle;
        hiddenContainer.appendChild(input);
      });
    }
  });
</script>
