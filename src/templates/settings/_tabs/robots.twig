{% import "_includes/forms.twig" as forms %}

<h2 class="heading first">{{ 'settings.robots.robots.directives.available.seo.field.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.robots.enable.which.directives.authors.can.text'|t('beacon') }}</p>

<table class="data fullwidth fixed-layout">
    <thead>
        <tr>
            <th class="beacon-col--directive">{{ 'settings.robots.directive.text'|t('beacon') }}</th>
            <th class="beacon-col--available">{{ 'settings.robots.available.text'|t('beacon') }}</th>
            <th>{{ 'settings.robots.description.text'|t('beacon') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for def in robotsDirectiveDefs %}
            <tr>
                <td><code>{{ def.label }}</code> <span class="light">({{ def.type }})</span></td>
                <td>
                    {{ forms.lightswitch({
                        name: 'robotsDirectivesEnabled[' ~ def.key ~ ']',
                        on: robotsEnabled[def.key] ?? false,
                        value: '1',
                    }) }}
                </td>
                <td>{{ def.help|t('beacon') }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
