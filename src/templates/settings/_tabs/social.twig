{% import "_includes/forms.twig" as forms %}

<h2 class="heading first">{{ 'settings.social.social.profiles.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.social.profile.urls.feed.schema.org.text'|t('beacon') }}</p>

{% set socialProfiles = settings.socialProfiles %}

<table class="data fullwidth beacon-social-table">
    <thead>
        <tr>
            <th scope="col" class="beacon-col--platform">{{ 'settings.social.platform.text'|t('beacon') }}</th>
            <th scope="col">{{ 'settings.social.profile.url.text'|t('beacon') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for p in beaconSocialPlatforms %}
        <tr>
            <th scope="row">
                <label for="socialProfile-{{ p.key }}">{{ p.label|t('beacon') }}</label>
            </th>
            <td>
                <input type="url"
                    id="socialProfile-{{ p.key }}"
                    class="text fullwidth"
                    name="socialProfiles[{{ p.key }}]"
                    value="{{ socialProfiles[p.key] ?? '' }}"
                    placeholder="{{ p.placeholder|t('beacon') }}"
                    autocomplete="off"
                    spellcheck="false">
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
