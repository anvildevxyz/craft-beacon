{% import "_includes/forms.twig" as forms %}

<h2 class="heading first">{{ 'settings.content.aiUsage.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.content.aiUsage.instructions'|t('beacon') }}</p>
{{ forms.selectField({
    label: 'settings.content.aiUsage.default.label'|t('beacon'),
    name: 'aiUsagePolicy',
    value: settings.aiUsagePolicy ?? 'allow',
    options: [
        { label: 'seoField.aiUsage.allow'|t('beacon'), value: 'allow' },
        { label: 'seoField.aiUsage.noTrain'|t('beacon'), value: 'no-train' },
        { label: 'seoField.aiUsage.noGenerative'|t('beacon'), value: 'no-generative-ai' },
        { label: 'seoField.aiUsage.noAi'|t('beacon'), value: 'no-ai' },
    ],
}) }}
{{ forms.textField({
    label: 'settings.content.aiUsage.policyUrl.label'|t('beacon'),
    instructions: 'settings.content.aiUsage.policyUrl.instructions'|t('beacon'),
    name: 'aiUsagePolicyUrl',
    value: settings.aiUsagePolicyUrl ?? '',
    placeholder: 'https://example.com/ai-policy',
}) }}
<hr>

<h2 class="heading">{{ 'settings.content.content.seo.defaults.by.section.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.content.click.token.insert.it.cursor.text'|t('beacon') }}</p>
<hr>

{% set tokens = [
    { token: '{title}', label: 'settings.content.entry.title.label'|t('beacon') },
    { token: '{siteName}', label: 'settings.content.site.name.label'|t('beacon') },
    { token: '{section}', label: 'settings.content.section.name.label'|t('beacon') },
    { token: '{type}', label: 'settings.content.entry.type.name.label'|t('beacon') },
    { token: '{author}', label: 'settings.content.entry.author.s.name.label'|t('beacon') },
    { token: '{parent}', label: 'settings.content.parent.entry.s.title.structure.label'|t('beacon') },
] %}

{% macro tokenPills(tokens) %}
    <div class="beacon-token-pills">
        {% for t in tokens %}
            <button type="button" class="beacon-token-pill" data-token="{{ t.token }}" title="{{ t.label }}">{{ t.token }}</button>
        {% endfor %}
    </div>
{% endmacro %}

<table class="data fullwidth beacon-content-table">
    <thead>
        <tr>
            <th class="beacon-content-table__section-col">{{ 'settings.content.section.text'|t('beacon') }}</th>
            <th>{{ 'settings.content.templates.text'|t('beacon') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for section in sections %}
            {% set defaults = settings.sectionSeoDefaults[section.handle] ?? {} %}
            <tr>
                <td>
                    <strong>{{ section.name }}</strong>
                    <div class="light code">{{ section.handle }}</div>
                </td>
                <td>
                    <div class="beacon-field">
                        <label class="beacon-field__label">{{ 'settings.content.title.template.text'|t('beacon') }}</label>
                        <input class="text fullwidth beacon-token-input" type="text"
                            name="sectionSeoDefaults[{{ section.handle }}][titleTemplate]"
                            value="{{ defaults.titleTemplate ?? '' }}"
                            placeholder="{{ 'settings.content.message.text'|t('beacon') }}">
                        {{ _self.tokenPills(tokens) }}
                    </div>
                    <div class="beacon-field">
                        <label class="beacon-field__label">{{ 'settings.content.description.template.text'|t('beacon') }}</label>
                        <textarea class="text fullwidth beacon-token-input" rows="4"
                            name="sectionSeoDefaults[{{ section.handle }}][descriptionTemplate]"
                            placeholder="{{ 'settings.content.learn.about.text'|t('beacon') }}">{{ defaults.descriptionTemplate ?? '' }}</textarea>
                        {{ _self.tokenPills(tokens) }}
                    </div>
                    <div class="beacon-field">
                        <label class="beacon-field__label">{{ 'settings.content.aiUsage.label'|t('beacon') }}</label>
                        {% set aiUsageOptions = {
                            '': 'settings.content.aiUsage.inherit'|t('beacon'),
                            'allow': 'seoField.aiUsage.allow'|t('beacon'),
                            'no-train': 'seoField.aiUsage.noTrain'|t('beacon'),
                            'no-generative-ai': 'seoField.aiUsage.noGenerative'|t('beacon'),
                            'no-ai': 'seoField.aiUsage.noAi'|t('beacon'),
                        } %}
                        <div class="select">
                            <select name="sectionSeoDefaults[{{ section.handle }}][aiUsage]">
                                {% for val, label in aiUsageOptions %}
                                    <option value="{{ val }}"{{ (defaults.aiUsage ?? '') == val ? ' selected' : '' }}>{{ label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
