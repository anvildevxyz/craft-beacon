{% import "_includes/forms.twig" as forms %}

<h2 class="heading first">{{ 'settings.geo.geo.export.provenance.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.geo.controls.markdown.export.policy.llms.text'|t('beacon') }}</p>
<hr>

{{ forms.lightswitchField({
    label: 'settings.geo.geoMarkdownEnabled.label'|t('beacon'),
    name: 'geoMarkdownEnabled',
    on: settings.geoMarkdownEnabled,
}) }}

{{ forms.lightswitchField({
    label: 'settings.geo.geoMarkdownNegotiateAcceptHeader.label'|t('beacon'),
    name: 'geoMarkdownNegotiateAcceptHeader',
    on: settings.geoMarkdownNegotiateAcceptHeader,
}) }}

{{ forms.lightswitchField({
    label: 'settings.geo.geoMarkdownAutoServeBots.label'|t('beacon'),
    instructions: 'settings.geo.geoMarkdownAutoServeBots.instructions'|t('beacon'),
    name: 'geoMarkdownAutoServeBots',
    on: settings.geoMarkdownAutoServeBots,
}) }}

{{ forms.lightswitchField({
    label: 'settings.geo.geoMarkdownMdSuffixEnabled.label'|t('beacon'),
    name: 'geoMarkdownMdSuffixEnabled',
    on: settings.geoMarkdownMdSuffixEnabled,
}) }}

<hr>

<h2 class="heading">{{ 'settings.geo.markdown.export.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.geo.render.strategy.stripped.css.classes.text'|t('beacon') }}</p>

{{ forms.lightswitchField({
    label: 'settings.geo.geoMarkdownExcerptFallbackToDescription.label'|t('beacon'),
