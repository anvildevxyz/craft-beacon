    name: 'geoMarkdownExcerptFallbackToDescription',
    on: settings.geoMarkdownExcerptFallbackToDescription,
}) }}

{{ forms.lightswitchField({
    label: 'settings.geo.geoProvenanceSchemaEnabled.label'|t('beacon'),
    instructions: 'settings.geo.geoProvenanceSchemaEnabled.instructions'|t('beacon'),
    name: 'geoProvenanceSchemaEnabled',
    on: settings.geoProvenanceSchemaEnabled,
}) }}

<hr>

<h2 class="heading">{{ 'settings.geo.geo.score.heading'|t('beacon') }}</h2>
<p class="light">{{ 'settings.geo.0.100.readiness.score.shown.text'|t('beacon') }}</p>

{{ forms.lightswitchField({
    label: 'settings.geo.geoScoreEnabled.label'|t('beacon'),
    name: 'geoScoreEnabled',
    on: settings.geoScoreEnabled,
}) }}
