{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'sitemap' %}
{% import '_includes/forms.twig' as forms %}
{% set title = 'Sitemap'|t('beacon') %}
{% set fullPageForm = true %}
{% set crumbs = [{ label: 'Beacon'|t('beacon'), url: cpUrl('beacon') }] %}

{% set changefreqOptions = [
    {label: 'Always'|t('beacon'), value: 'always'},
    {label: 'Hourly'|t('beacon'), value: 'hourly'},
    {label: 'Daily'|t('beacon'), value: 'daily'},
    {label: 'Weekly'|t('beacon'), value: 'weekly'},
    {label: 'Monthly'|t('beacon'), value: 'monthly'},
    {label: 'Yearly'|t('beacon'), value: 'yearly'},
    {label: 'Never'|t('beacon'), value: 'never'},
] %}

{% block content %}
    <input type="hidden" name="action" value="beacon/sitemap-settings/save">
    <input type="hidden" name="siteId" value="{{ site.id }}">
    {{ redirectInput('beacon/sitemap?site=' ~ site.handle) }}
    {{ csrfInput() }}

    {% for handle in settings.newsSections %}
        <input type="hidden" name="newsSections[]" value="{{ handle }}">
    {% endfor %}

    {% include 'beacon/_includes/site-selector' with { sites, site, baseUrl: cpUrl('beacon/sitemap') } only %}

    {% if allSections is empty %}
        <div class="zilch dashed-border">
            <p>{{ 'No sections defined yet.'|t('beacon') }}</p>
        </div>
    {% else %}
        <table class="data fullwidth beacon-sitemap-table">
            <thead>
                <tr>
                    <th scope="col">{{ 'Section'|t('beacon') }}</th>
                    <th scope="col" class="thin">{{ 'Enabled'|t('beacon') }}</th>
                    <th scope="col" class="beacon-col--priority">{{ 'Priority'|t('beacon') }} <span class="light">(0–1)</span></th>
                    <th scope="col" class="beacon-col--changefreq">{{ 'Change frequency'|t('beacon') }}</th>
                </tr>
            </thead>
            <tbody>
            {% for s in allSections %}
                {% set meta = settings.sectionSitemap[s.value] ?? {} %}
                {% set isEnabled = s.value in settings.sections and s.value not in settings.excludeSections %}
                <tr>
                    <th scope="row">
                        <strong>{{ s.label }}</strong>
                        <div class="light"><code>{{ s.value }}</code></div>
                    </th>
                    <td class="thin">
                        <input type="checkbox" name="sections[]" value="{{ s.value }}"
                            id="sitemap-enabled-{{ s.value }}"
                            aria-label="{{ 'Enable {section}'|t('beacon', { section: s.label }) }}"
                            {% if isEnabled %}checked{% endif %}>
                    </td>
                    <td>
                        <input class="text fullwidth" type="number"
                            name="sectionSitemap[{{ s.value }}][priority]"
                            min="0" max="1" step="0.1"
                            value="{{ meta.priority ?? '0.8' }}"
                            placeholder="0.8"
                            aria-label="{{ 'Priority for {section}'|t('beacon', { section: s.label }) }}">
                    </td>
                    <td>
                        {{ forms.select({
                            id: 'section-changefreq-' ~ s.value,
                            name: 'sectionSitemap[' ~ s.value ~ '][changefreq]',
                            options: changefreqOptions,
                            value: meta.changefreq ?? 'weekly',
                        }) }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <hr>

        <h2 class="heading">{{ 'GEO Markdown front matter (per section)'|t('beacon') }}</h2>
        <p class="light">{{ 'One `key: value` pair per line. Overrides site-level defaults; in turn overridden by per-entry SEO field values. Empty boxes inherit from site defaults.'|t('beacon') }}</p>

        {% for s in allSections %}
            {{ forms.textareaField({
                label: s.label ~ ' (' ~ s.value ~ ')',
                name: 'geoMarkdownFrontMatter[' ~ s.value ~ ']',
                value: (settings.geoMarkdownFrontMatter[s.value] ?? {})|map((v, k) => k ~ ': ' ~ v)|join("\n"),
                rows: 3,
                placeholder: 'audience: developers'|t('beacon'),
            }) }}
        {% endfor %}
    {% endif %}
{% endblock %}
