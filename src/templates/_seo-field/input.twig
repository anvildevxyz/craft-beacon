{% import '_includes/forms.twig' as forms %}
{% set value = value ?? {} %}
{% set seoTitleValue = value.title ?? '' %}
{% set seoDescriptionValue = value.description ?? '' %}
{% set fallback = fallback ?? { title: '', description: '', ogImage: '', sourceMap: {} } %}
{% set fallbackTitle = fallback.title ?? '' %}
{% set fallbackDescription = fallback.description ?? '' %}
{% set fallbackOgImage = fallback.ogImage ?? '' %}
{% set liteMode = liteMode ?? true %}

<div class="beacon-seo-field{% if liteMode %} is-lite{% endif %}"
    data-beacon-seo-field
    data-seo-lite-mode="{{ liteMode ? '1' : '0' }}"
    data-field-prefix="{{ name }}"
    data-bp-resolve-url="{{ resolveUrl ?? '' }}"
    data-bp-entry-id="{{ entryId ?? '' }}"
    data-bp-site-id="{{ siteId ?? '' }}"
    data-bp-fallback="{{ fallback|json_encode }}"
>
    {% set sectionDefaults = sectionDefaults ?? {} %}
    {% set hasSectionTitle = (sectionDefaults.titleTemplate ?? '')|trim != '' %}
    {% set hasSectionDesc  = (sectionDefaults.descriptionTemplate ?? '')|trim != '' %}
    {% if hasSectionTitle or hasSectionDesc %}
        <p class="instructions">
            {{ 'seoField.section.defaults.active.section.text'|t('beacon') }}
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'seoField.edit.section.defaults.text'|t('beacon') }} ↗</a>
        </p>
    {% endif %}

    <details class="beacon-seo-group" open>
        <summary class="beacon-seo-group-summary">
            <span class="beacon-seo-group-title">{{ 'seoField.search.social.seo.text'|t('beacon') }}</span>
            <span class="beacon-seo-group-hint">{{ 'seoField.title.description.image.canonical.robots.text'|t('beacon') }}</span>
        </summary>
        <div class="beacon-seo-group-body">

    {{ forms.textField({
        label: 'seoField.seo.title.label'|t('beacon'),
        instructions: liteMode ? null : 'seoField.leave.blank.inherit.placeholder.shows.instructions'|t('beacon'),
        name: name ~ '[title]',
        value: seoTitleValue,
        placeholder: fallbackTitle,
        inputAttributes: { 'data-bp-fallback-input': 'title' },
    }) }}
    <div class="beacon-seo-meter" data-meter-name="{{ name }}[title]" data-meter-suffix="[title]" data-meter-min="50" data-meter-max="60">
        <span class="beacon-seo-meter-count">{{ seoTitleValue|length }}</span>
        <span class="beacon-seo-meter-range">{{ 'seoField.50.60.chars.text'|t('beacon') }}</span>
        <span class="beacon-seo-meter-bar"><span class="beacon-seo-meter-fill"></span></span>
        {% if not liteMode %}
        <span class="beacon-source-badge" data-bp-source-badge="title"
              data-bp-has-section="{{ hasSectionTitle ? '1' : '0' }}"
              title="{{ 'seoField.where.resolved.seo.title.comes.text'|t('beacon') }}"
        ></span>
        {% endif %}
    </div>
    {% if not liteMode %}
    <div class="beacon-source-line" data-bp-source-line="title">
        {% if hasSectionTitle %}
            <span>{{ 'seoField.inheriting.title.template.section.defaults.text'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'seoField.edit.section.defaults.text'|t('beacon') }} ↗</a>
        {% else %}
            <span>{{ 'seoField.inheriting.title.template.global.defaults.text'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/general') }}" target="_blank" rel="noopener">{{ 'seoField.edit.global.defaults.text'|t('beacon') }} ↗</a>
        {% endif %}
    </div>
    {% endif %}

    {{ forms.textareaField({
        label: 'seoField.seo.description.label'|t('beacon'),
        instructions: liteMode ? null : 'seoField.aim.150.160.characters.placeholder.instructions'|t('beacon'),
        name: name ~ '[description]',
        value: seoDescriptionValue,
        rows: 3,
        placeholder: fallbackDescription,
        inputAttributes: { 'data-bp-fallback-input': 'description' },
    }) }}
    <div class="beacon-seo-meter" data-meter-name="{{ name }}[description]" data-meter-suffix="[description]" data-meter-min="150" data-meter-max="160">
        <span class="beacon-seo-meter-count">{{ seoDescriptionValue|length }}</span>
        <span class="beacon-seo-meter-range">{{ 'seoField.150.160.chars.text'|t('beacon') }}</span>
        <span class="beacon-seo-meter-bar"><span class="beacon-seo-meter-fill"></span></span>
        {% if not liteMode %}
        <span class="beacon-source-badge" data-bp-source-badge="description"
              data-bp-has-section="{{ hasSectionDesc ? '1' : '0' }}"
              title="{{ 'seoField.where.resolved.description.comes.entry.text'|t('beacon') }}"
        ></span>
        {% endif %}
    </div>
    {% if not liteMode %}
    <div class="beacon-source-line" data-bp-source-line="description">
        {% if hasSectionDesc %}
            <span>{{ 'seoField.inheriting.description.template.section.defaults.text'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'seoField.edit.section.defaults.text'|t('beacon') }} ↗</a>
        {% else %}
            <span>{{ 'seoField.inheriting.description.template.global.defaults.text'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/general') }}" target="_blank" rel="noopener">{{ 'seoField.edit.global.defaults.text'|t('beacon') }} ↗</a>
        {% endif %}
    </div>
    {% endif %}

    {% if not liteMode %}
    <section class="beacon-seo-checklist" data-seo-checklist data-field-prefix="{{ name }}">
        <div class="beacon-seo-checklist-header">
            <strong>{{ 'seoField.seo.quality.checklist.text'|t('beacon') }}</strong>
            <span class="beacon-seo-checklist-score"><span data-seo-score>0</span>/100</span>
        </div>
        <ul class="beacon-seo-checklist-items">
            <li data-seo-check="titleLength">{{ 'seoField.title.length.recommended.range.text'|t('beacon') }}</li>
            <li data-seo-check="descriptionLength">{{ 'seoField.description.length.recommended.range.text'|t('beacon') }}</li>
            <li data-seo-check="canonical">{{ 'seoField.canonical.url.resolvable.text'|t('beacon') }}</li>
            <li data-seo-check="robots">{{ 'seoField.robots.directives.not.over.restrictive.text'|t('beacon') }}</li>
            <li data-seo-check="schema">{{ 'seoField.least.one.schema.source.present.text'|t('beacon') }}</li>
            <li data-seo-check="social">{{ 'seoField.social.preview.has.title.description.text'|t('beacon') }}</li>
        </ul>
    </section>
    {% endif %}

    {% set ogImageId = value.ogImageId ?? null %}
    {% set ogImageAsset = ogImageId ? craft.assets().id(ogImageId).status(null).one() : null %}
    {{ forms.elementSelectField({
        label: 'seoField.seo.image.label'|t('beacon'),
        instructions: 'seoField.used.as.open.graph.twitter.instructions'|t('beacon'),
        id: name ~ '-ogImageId',
        name: name ~ '[ogImageId]',
        elementType: 'craft\\elements\\Asset',
        elements: ogImageAsset ? [ogImageAsset] : [],
        limit: 1,
        viewMode: 'large',
        criteria: { kind: 'image' },
    }) }}

    {# Inherited image preview — shown only when the entry has no explicit
       SEO image and the resolver landed on a global/section/entry-derived
       image. The JS keeps it in sync as fallbacks change. #}
    <div class="beacon-seo-inherited-image"
        data-bp-inherited-image
        {% if ogImageId or fallbackOgImage == '' %}hidden{% endif %}
    >
        <span class="beacon-seo-inherited-image-label">{{ 'seoField.inherited.image.text'|t('beacon') }}</span>
        <img data-bp-inherited-image-img src="{{ fallbackOgImage }}" alt="" loading="lazy">
        <span class="beacon-seo-inherited-image-help light">{{ 'seoField.used.no.entry.image.set.text'|t('beacon') }}</span>
    </div>

    {{ forms.textField({
        label: 'seoField.canonical.url.label'|t('beacon'),
        instructions: 'seoField.leave.blank.auto.instructions'|t('beacon'),
        name: name ~ '[canonical]',
        value: value.canonical ?? '',
    }) }}

    {% set robotsDefs = robotsDirectiveDefs ?? [] %}
    {% if robotsDefs %}
        <section class="beacon-seo-section beacon-seo-robots">
            <h3 class="beacon-seo-section-title">{{ 'seoField.robots.directives.heading'|t('beacon') }}</h3>
            <div class="beacon-seo-robots-warning" data-bp-robots-warn aria-live="polite"></div>
            <div class="beacon-seo-robots-grid">
                {% for def in robotsDefs %}
                    {% set fieldName = name ~ '[robots][' ~ def.key ~ ']' %}
                    {% set current = value.robots[def.key] ?? null %}
                    {% if def.type == 'bool' %}
                        <div class="beacon-seo-robots-item" title="{{ (def.help ?? '')|t('beacon') }}">
                            {{ forms.checkboxField({
                                label: def.label,
                                name: fieldName,
                                checked: current ?? false,
                            }) }}
                        </div>
                    {% elseif def.type == 'enum' %}
                        {% set enumOptions = [{ label: '— ' ~ ('seoField.off.text'|t('beacon')) ~ ' —', value: '' }] %}
                        {% for opt in def.options %}
                            {% set enumOptions = enumOptions|merge([{ label: opt, value: opt }]) %}
                        {% endfor %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.selectField({
                                label: def.label,
                                name: fieldName,
                                value: current ?? '',
                                options: enumOptions,
                            }) }}
                        </div>
                    {% elseif def.type == 'int' %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.textField({
                                label: def.label,
                                name: fieldName,
                                type: 'number',
                                value: current is same as(false) or current is null ? '' : current,
                                size: 8,
                                placeholder: def.placeholder ? (def.placeholder|t('beacon')) : '',
                            }) }}
                        </div>
                    {% elseif def.type == 'datetime' %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.textField({
                                label: def.label,
                                name: fieldName,
                                value: current ?? '',
                                placeholder: def.placeholder ? (def.placeholder|t('beacon')) : '',
                            }) }}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {% if preview %}
        <section class="beacon-seo-section beacon-seo-previews">
            <h3 class="beacon-seo-section-title">{{ 'seoField.search.social.previews.heading'|t('beacon') }}</h3>
            {% if not liteMode %}
            <div class="beacon-preview-callout" data-bp-missing-fields aria-live="polite" hidden></div>
            {% endif %}
            {{ preview|raw }}
        </section>
    {% endif %}

        </div>
    </details>

    <details class="beacon-seo-group"{{ liteMode ? '' : ' open' }}>
        <summary class="beacon-seo-group-summary">
            <span class="beacon-seo-group-title">{{ 'seoField.ai.structured.data.geo.text'|t('beacon') }}</span>
            <span class="beacon-seo-group-hint">{{ 'seoField.json.ld.schema.ai.markdown.text'|t('beacon') }}</span>
        </summary>
        <div class="beacon-seo-group-body">

    <section class="beacon-seo-section">
        <h3 class="beacon-seo-section-title">{{ 'seoField.structured.data.json.ld.heading'|t('beacon') }}</h3>

        {% set inherited = inheritedSchemas ?? [] %}
        {% if inherited %}
            <div class="beacon-schema-banner" role="note">
                <p class="beacon-schema-banner-title">
                    {{ 'seoField.entry.already.emits.text'|t('beacon') }}
                </p>
                <ul class="beacon-schema-banner-list">
                    {% for row in inherited %}
                        <li>
                            <strong>{{ row.type }}</strong>
                            <span class="light">— {{ row.source }}</span>
                            {% if row.editUrl is defined and row.editUrl %}
                                <a href="{{ row.editUrl }}" class="beacon-schema-banner-edit" target="_blank" rel="noopener">{{ 'seoField.edit.text'|t('beacon') }} ↗</a>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <p class="beacon-schema-banner-help">
                    {{ 'seoField.add.one.below.only.extra.text'|t('beacon') }}
                </p>
            </div>
        {% else %}
            <p class="beacon-seo-section-help">{{ 'seoField.attach.entry.specific.structured.data.text'|t('beacon') }}</p>
        {% endif %}

        {% set addons = value.schemaAddons ?? [] %}
        {# `inputName` is the namespaced field name as Craft will see it on POST
           — JS uses this when building hidden inputs for new schema cards so
           the names line up with the namespace Craft expects. #}
        {% set fieldConfig = {
            sources: schemaSources ?? [],
            properties: schemaProperties ?? {},
            types: schemaTypes ?? [],
            entryId: entryId ?? null,
            inputName: craft.app.view.namespaceInputName(name),
        } %}
        {# JSON_HEX_TAG escapes < and > so a value containing "</script>" cannot
           break out of this inline JSON island (Craft's Json::encode flag set). #}
        <script type="application/json" data-beacon-seo-field-config="{{ name }}">{{ fieldConfig|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT') b-or constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>

        <div
            class="beacon-schema-cards"
            data-beacon-schema-cards
            data-field-name="{{ name }}"
            data-next-index="{{ addons|length }}"
        >
            {% if not addons %}
                <p class="beacon-schema-empty" data-beacon-schema-empty>
                    {{ 'seoField.no.additional.schemas.yet.text'|t('beacon') }}
                </p>
            {% endif %}
            {% for i, schema in addons %}
                {% set mapping = schema.mapping is iterable ? schema.mapping : {} %}
                <div class="beacon-schema-card" data-beacon-schema-card data-schema-index="{{ i }}">
                    <input
                        type="hidden"
                        name="{{ name }}[schemaAddons][{{ i }}][type]"
                        value="{{ schema.type ?? 'Article' }}"
                        data-schema-type-input
                    >
                    <input
                        type="hidden"
                        name="{{ name }}[schemaAddons][{{ i }}][mapping]"
                        value="{{ mapping|json_encode }}"
                        data-schema-mapping-input
                    >
                    <div class="beacon-schema-card-body" data-card-body></div>
                    <div class="beacon-schema-card-actions">
                        <button type="button" class="btn small" data-card-edit>{{ 'seoField.edit.text'|t('beacon') }}</button>
                        <button type="button" class="btn small" data-card-remove aria-label="{{ 'seoField.remove.schema.ariaLabel'|t('beacon') }}">{{ 'seoField.remove.text'|t('beacon') }}</button>
                    </div>
                </div>
            {% endfor %}
        </div>

        <button
            type="button"
            class="btn add icon"
            data-beacon-add-schema
        >{{ 'seoField.add.schema.text'|t('beacon') }}</button>
    </section>

    <section class="beacon-seo-section beacon-seo-ai-markdown">
        <h3 class="beacon-seo-section-title">{{ 'seoField.ai.markdown.heading'|t('beacon') }}</h3>
        <p class="light">{{ 'seoField.per.entry.overrides.geo.markdown.text'|t('beacon') }}</p>
        {% set aiMd = value.aiMarkdown ?? {} %}
        {{ forms.selectField({
            label: 'seoField.include.markdown.export.label'|t('beacon'),
            name: name ~ '[aiMarkdown][enabled]',
            options: [
                { label: 'seoField.inherit.site.section.settings.label'|t('beacon'), value: 'inherit' },
                { label: 'seoField.always.include.label'|t('beacon'), value: 'include' },
                { label: 'seoField.always.exclude.label'|t('beacon'), value: 'exclude' },
            ],
            value: aiMd.enabled ?? 'inherit',
        }) }}
        {{ forms.textareaField({
            label: 'seoField.custom.front.matter.label'|t('beacon'),
            instructions: 'seoField.one.key.value.pair.per.instructions'|t('beacon'),
            name: name ~ '[aiMarkdown][customFrontMatter]',
            value: aiMd.customFrontMatter ?? '',
            rows: 4,
            placeholder: 'seoField.audience.developers.placeholder'|t('beacon'),
        }) }}
    </section>

        </div>
    </details>

    {# JS + CSS live in BeaconSeoFieldAsset (registered by BeaconSeoField::getInputHtml). #}
</div>
