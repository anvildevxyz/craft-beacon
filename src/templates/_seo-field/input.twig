{% import '_includes/forms.twig' as forms %}
{% set value = value ?? {} %}
{% set seoTitleValue = value.title ?? '' %}
{% set seoDescriptionValue = value.description ?? '' %}
{% set fallback = fallback ?? { title: '', description: '', ogImage: '', sourceMap: {} } %}
{% set fallbackTitle = fallback.title ?? '' %}
{% set fallbackDescription = fallback.description ?? '' %}
{% set fallbackOgImage = fallback.ogImage ?? '' %}

<div class="beacon-seo-field"
    data-beacon-seo-field
    data-bp-resolve-url="{{ resolveUrl ?? '' }}"
    data-bp-entry-id="{{ entryId ?? '' }}"
    data-bp-site-id="{{ siteId ?? '' }}"
    data-bp-fallback="{{ fallback|json_encode }}"
>
    {% set sectionDefaults = sectionDefaults ?? {} %}
    {% set hasSectionTitle = (sectionDefaults.titleTemplate ?? '')|trim != '' %}
    {% set hasSectionDesc  = (sectionDefaults.descriptionTemplate ?? '')|trim != '' %}
    {% if hasSectionTitle or hasSectionDesc %}
        <p class="instructions">
            {{ 'Section defaults are active for this section.'|t('beacon') }}
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'Edit section defaults'|t('beacon') }} ↗</a>
        </p>
    {% endif %}

    <details class="beacon-seo-group" open>
        <summary class="beacon-seo-group-summary">
            <span class="beacon-seo-group-title">{{ 'Search & social (SEO)'|t('beacon') }}</span>
            <span class="beacon-seo-group-hint">{{ 'Title, description, image, canonical, robots, previews'|t('beacon') }}</span>
        </summary>
        <div class="beacon-seo-group-body">

    {{ forms.textField({
        label: 'SEO Title'|t('beacon'),
        instructions: 'Leave blank to inherit. The placeholder shows the live resolved fallback.'|t('beacon'),
        name: name ~ '[title]',
        value: seoTitleValue,
        placeholder: fallbackTitle,
        inputAttributes: { 'data-bp-fallback-input': 'title' },
    }) }}
    <div class="beacon-seo-meter" data-meter-name="{{ name }}[title]" data-meter-suffix="[title]" data-meter-min="50" data-meter-max="60">
        <span class="beacon-seo-meter-count">{{ seoTitleValue|length }}</span>
        <span class="beacon-seo-meter-range">{{ '/ 50–60 chars'|t('beacon') }}</span>
        <span class="beacon-seo-meter-bar"><span class="beacon-seo-meter-fill"></span></span>
        <span class="beacon-source-badge" data-bp-source-badge="title"
              data-bp-has-section="{{ hasSectionTitle ? '1' : '0' }}"
              title="{{ 'Where the resolved SEO title comes from (entry override / section default / global default).'|t('beacon') }}"
        ></span>
    </div>
    <div class="beacon-source-line" data-bp-source-line="title">
        {% if hasSectionTitle %}
            <span>{{ 'Inheriting title template from section defaults.'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'Edit section defaults'|t('beacon') }} ↗</a>
        {% else %}
            <span>{{ 'Inheriting title template from global defaults.'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/general') }}" target="_blank" rel="noopener">{{ 'Edit global defaults'|t('beacon') }} ↗</a>
        {% endif %}
    </div>

    {{ forms.textareaField({
        label: 'SEO Description'|t('beacon'),
        instructions: 'Aim for 150-160 characters. The placeholder shows the live resolved fallback.'|t('beacon'),
        name: name ~ '[description]',
        value: seoDescriptionValue,
        rows: 3,
        placeholder: fallbackDescription,
        inputAttributes: { 'data-bp-fallback-input': 'description' },
    }) }}
    <div class="beacon-seo-meter" data-meter-name="{{ name }}[description]" data-meter-suffix="[description]" data-meter-min="150" data-meter-max="160">
        <span class="beacon-seo-meter-count">{{ seoDescriptionValue|length }}</span>
        <span class="beacon-seo-meter-range">{{ '/ 150–160 chars'|t('beacon') }}</span>
        <span class="beacon-seo-meter-bar"><span class="beacon-seo-meter-fill"></span></span>
        <span class="beacon-source-badge" data-bp-source-badge="description"
              data-bp-has-section="{{ hasSectionDesc ? '1' : '0' }}"
              title="{{ 'Where the resolved description comes from (entry override / section default / global default).'|t('beacon') }}"
        ></span>
    </div>
    <div class="beacon-source-line" data-bp-source-line="description">
        {% if hasSectionDesc %}
            <span>{{ 'Inheriting description template from section defaults.'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/content') }}" target="_blank" rel="noopener">{{ 'Edit section defaults'|t('beacon') }} ↗</a>
        {% else %}
            <span>{{ 'Inheriting description template from global defaults.'|t('beacon') }}</span>
            <a href="{{ cpUrl('beacon/settings/general') }}" target="_blank" rel="noopener">{{ 'Edit global defaults'|t('beacon') }} ↗</a>
        {% endif %}
    </div>

    <section class="beacon-seo-checklist" data-seo-checklist data-field-prefix="{{ name }}">
        <div class="beacon-seo-checklist-header">
            <strong>{{ 'SEO quality checklist'|t('beacon') }}</strong>
            <span class="beacon-seo-checklist-score"><span data-seo-score>0</span>/100</span>
        </div>
        <ul class="beacon-seo-checklist-items">
            <li data-seo-check="titleLength">{{ 'Title length is in recommended range'|t('beacon') }}</li>
            <li data-seo-check="descriptionLength">{{ 'Description length is in recommended range'|t('beacon') }}</li>
            <li data-seo-check="canonical">{{ 'Canonical URL is resolvable'|t('beacon') }}</li>
            <li data-seo-check="robots">{{ 'Robots directives are not over-restrictive'|t('beacon') }}</li>
            <li data-seo-check="schema">{{ 'At least one schema source is present'|t('beacon') }}</li>
            <li data-seo-check="social">{{ 'Social preview has title/description coverage'|t('beacon') }}</li>
        </ul>
    </section>

    {% set ogImageId = value.ogImageId ?? null %}
    {% set ogImageAsset = ogImageId ? craft.assets().id(ogImageId).status(null).one() : null %}
    {{ forms.elementSelectField({
        label: 'SEO image'|t('beacon'),
        instructions: 'Used as the Open Graph / Twitter card image. Recommended 1200×630.'|t('beacon'),
        id: name ~ '-ogImageId',
        name: name ~ '[ogImageId]',
        elementType: 'craft\\elements\\Asset',
        elements: ogImageAsset ? [ogImageAsset] : [],
        limit: 1,
        viewMode: 'large',
        criteria: { kind: 'image' },
    }) }}

    {# Inherited image preview — shown only when the entry has no explicit
       SEO image and the resolver landed on a global/section/entry-derived
       image. The JS keeps it in sync as fallbacks change. #}
    <div class="beacon-seo-inherited-image"
        data-bp-inherited-image
        {% if ogImageId or fallbackOgImage == '' %}hidden{% endif %}
    >
        <span class="beacon-seo-inherited-image-label">{{ 'Inherited image:'|t('beacon') }}</span>
        <img data-bp-inherited-image-img src="{{ fallbackOgImage }}" alt="" loading="lazy">
        <span class="beacon-seo-inherited-image-help light">{{ 'Used when no entry image is set.'|t('beacon') }}</span>
    </div>

    {{ forms.textField({
        label: 'Canonical URL'|t('beacon'),
        instructions: 'Leave blank for auto.'|t('beacon'),
        name: name ~ '[canonical]',
        value: value.canonical ?? '',
    }) }}

    {% set robotsDefs = robotsDirectiveDefs ?? [] %}
    {% if robotsDefs %}
        <section class="beacon-seo-section beacon-seo-robots">
            <h3 class="beacon-seo-section-title">{{ 'Robots directives'|t('beacon') }}</h3>
            <div class="beacon-seo-robots-warning" data-bp-robots-warn aria-live="polite"></div>
            <div class="beacon-seo-robots-grid">
                {% for def in robotsDefs %}
                    {% set fieldName = name ~ '[robots][' ~ def.key ~ ']' %}
                    {% set current = value.robots[def.key] ?? null %}
                    {% if def.type == 'bool' %}
                        <div class="beacon-seo-robots-item" title="{{ (def.help ?? '')|t('beacon') }}">
                            {{ forms.checkboxField({
                                label: def.label,
                                name: fieldName,
                                checked: current ?? false,
                            }) }}
                        </div>
                    {% elseif def.type == 'enum' %}
                        {% set enumOptions = [{ label: '— ' ~ ('off'|t('beacon')) ~ ' —', value: '' }] %}
                        {% for opt in def.options %}
                            {% set enumOptions = enumOptions|merge([{ label: opt, value: opt }]) %}
                        {% endfor %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.selectField({
                                label: def.label,
                                name: fieldName,
                                value: current ?? '',
                                options: enumOptions,
                            }) }}
                        </div>
                    {% elseif def.type == 'int' %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.textField({
                                label: def.label,
                                name: fieldName,
                                type: 'number',
                                value: current is same as(false) or current is null ? '' : current,
                                size: 8,
                                placeholder: def.placeholder ? (def.placeholder|t('beacon')) : '',
                            }) }}
                        </div>
                    {% elseif def.type == 'datetime' %}
                        <div class="beacon-seo-robots-item beacon-seo-robots-item-wide">
                            {{ forms.textField({
                                label: def.label,
                                name: fieldName,
                                value: current ?? '',
                                placeholder: def.placeholder ? (def.placeholder|t('beacon')) : '',
                            }) }}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {% if preview %}
        <section class="beacon-seo-section beacon-seo-previews">
            <h3 class="beacon-seo-section-title">{{ 'Search & social previews'|t('beacon') }}</h3>
            <div class="beacon-preview-callout" data-bp-missing-fields aria-live="polite" hidden></div>
            {{ preview|raw }}
        </section>
    {% endif %}

        </div>
    </details>

    <details class="beacon-seo-group" open>
        <summary class="beacon-seo-group-summary">
            <span class="beacon-seo-group-title">{{ 'AI & structured data (GEO)'|t('beacon') }}</span>
            <span class="beacon-seo-group-hint">{{ 'JSON-LD schema and AI Markdown export'|t('beacon') }}</span>
        </summary>
        <div class="beacon-seo-group-body">

    <section class="beacon-seo-section">
        <h3 class="beacon-seo-section-title">{{ 'Structured data (JSON-LD)'|t('beacon') }}</h3>

        {% set inherited = inheritedSchemas ?? [] %}
        {% if inherited %}
            <div class="beacon-schema-banner" role="note">
                <p class="beacon-schema-banner-title">
                    {{ 'This entry already emits:'|t('beacon') }}
                </p>
                <ul class="beacon-schema-banner-list">
                    {% for row in inherited %}
                        <li>
                            <strong>{{ row.type }}</strong>
                            <span class="light">— {{ row.source }}</span>
                            {% if row.editUrl is defined and row.editUrl %}
                                <a href="{{ row.editUrl }}" class="beacon-schema-banner-edit" target="_blank" rel="noopener">{{ 'Edit'|t('beacon') }} ↗</a>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <p class="beacon-schema-banner-help">
                    {{ 'Add one below only for extra types.'|t('beacon') }}
                </p>
            </div>
        {% else %}
            <p class="beacon-seo-section-help">{{ 'Attach entry-specific structured data beyond global defaults.'|t('beacon') }}</p>
        {% endif %}

        {% set addons = value.schemaAddons ?? [] %}
        {# `inputName` is the namespaced field name as Craft will see it on POST
           — JS uses this when building hidden inputs for new schema cards so
           the names line up with the namespace Craft expects. #}
        {% set fieldConfig = {
            sources: schemaSources ?? [],
            properties: schemaProperties ?? {},
            types: schemaTypes ?? [],
            entryId: entryId ?? null,
            inputName: craft.app.view.namespaceInputName(name),
        } %}
        {# JSON_HEX_TAG escapes < and > so a value containing "</script>" cannot
           break out of this inline JSON island (Craft's Json::encode flag set). #}
        <script type="application/json" data-beacon-seo-field-config="{{ name }}">{{ fieldConfig|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT') b-or constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>

        <div
            class="beacon-schema-cards"
            data-beacon-schema-cards
            data-field-name="{{ name }}"
            data-next-index="{{ addons|length }}"
        >
            {% if not addons %}
                <p class="beacon-schema-empty" data-beacon-schema-empty>
                    {{ 'No additional schemas yet.'|t('beacon') }}
                </p>
            {% endif %}
            {% for i, schema in addons %}
                {% set mapping = schema.mapping is iterable ? schema.mapping : {} %}
                <div class="beacon-schema-card" data-beacon-schema-card data-schema-index="{{ i }}">
                    <input
                        type="hidden"
                        name="{{ name }}[schemaAddons][{{ i }}][type]"
                        value="{{ schema.type ?? 'Article' }}"
                        data-schema-type-input
                    >
                    <input
                        type="hidden"
                        name="{{ name }}[schemaAddons][{{ i }}][mapping]"
                        value="{{ mapping|json_encode }}"
                        data-schema-mapping-input
                    >
                    <div class="beacon-schema-card-body" data-card-body></div>
                    <div class="beacon-schema-card-actions">
                        <button type="button" class="btn small" data-card-edit>{{ 'Edit'|t('beacon') }}</button>
                        <button type="button" class="btn small" data-card-remove aria-label="{{ 'Remove schema'|t('beacon') }}">{{ 'Remove'|t('beacon') }}</button>
                    </div>
                </div>
            {% endfor %}
        </div>

        <button
            type="button"
            class="btn add icon"
            data-beacon-add-schema
        >{{ 'Add schema'|t('beacon') }}</button>
    </section>

    <section class="beacon-seo-section beacon-seo-ai-markdown">
        <h3 class="beacon-seo-section-title">{{ 'AI Markdown'|t('beacon') }}</h3>
        <p class="light">{{ 'Per-entry overrides for the GEO Markdown export. Inherits from site/section defaults when set to "Inherit".'|t('beacon') }}</p>
        {% set aiMd = value.aiMarkdown ?? {} %}
        {{ forms.selectField({
            label: 'Include in Markdown export'|t('beacon'),
            name: name ~ '[aiMarkdown][enabled]',
            options: [
                { label: 'Inherit from site/section settings'|t('beacon'), value: 'inherit' },
                { label: 'Always include'|t('beacon'), value: 'include' },
                { label: 'Always exclude'|t('beacon'), value: 'exclude' },
            ],
            value: aiMd.enabled ?? 'inherit',
        }) }}
        {{ forms.textareaField({
            label: 'Custom front matter'|t('beacon'),
            instructions: 'One `key: value` pair per line. Highest precedence — overrides site and section defaults.'|t('beacon'),
            name: name ~ '[aiMarkdown][customFrontMatter]',
            value: aiMd.customFrontMatter ?? '',
            rows: 4,
            placeholder: 'audience: developers'|t('beacon'),
        }) }}
    </section>

        </div>
    </details>

    {# JS + CSS live in BeaconSeoFieldAsset (registered by BeaconSeoField::getInputHtml). #}
</div>
