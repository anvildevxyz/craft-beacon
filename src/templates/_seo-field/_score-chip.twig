{# @var score \anvildev\beacon\models\GeoScore|null #}
{# @var weakestLabel string|null #}
{# @var elementId int #}
{# @var siteId int #}
{% if score is not null %}
    {% set band = score.score >= 80 ? 'top' : score.score >= 60 ? 'good' : score.score >= 30 ? 'low' : 'stale' %}
    <a class="beacon-geo-score-chip beacon-geo-score-chip--{{ band }}"
       href="{{ cpUrl('beacon/geo-score/drill-down', { elementId: elementId, siteId: siteId }) }}"
       aria-label="{{ 'seoField.scoreChip.geo.score.100.open.details.ariaLabel'|t('beacon', { n: score.score }) }}">
        <span class="beacon-geo-score-chip__label">{{ 'seoField.scoreChip.geo.text'|t('beacon') }}</span>
        <span class="beacon-geo-score-chip__value">{{ score.score }}<span class="beacon-geo-score-chip__total">/100</span></span>
        {% if weakestLabel %}
            <span class="beacon-geo-score-chip__weakest" title="{{ 'seoField.scoreChip.lowest.scoring.pillar.fix.first.text'|t('beacon') }}">
                {{ 'seoField.scoreChip.weakest.text'|t('beacon', { pillar: weakestLabel }) }}
            </span>
        {% endif %}
        <span class="beacon-geo-score-chip__details" aria-hidden="true">{{ 'seoField.scoreChip.details.text'|t('beacon') }}</span>
    </a>
{% else %}
    <span class="beacon-geo-score-chip beacon-geo-score-chip--pending"
          data-beacon-geo-chip
          data-element-id="{{ elementId }}"
          data-site-id="{{ siteId }}"
          data-idle-label="{{ 'seoField.scoreChip.computes.next.save.text'|t('beacon') }}">
        <span class="beacon-geo-score-chip__label">{{ 'seoField.scoreChip.geo.text'|t('beacon') }}</span>
        <span class="beacon-geo-score-chip__value">—</span>
        <span class="beacon-geo-score-chip__pending">
            {{ 'seoField.scoreChip.computing.text'|t('beacon') }}
        </span>
    </span>
{% endif %}
