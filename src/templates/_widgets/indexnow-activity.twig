{% set siteHandles = {} %}
{% for s in sites %}{% set siteHandles = siteHandles|merge({(s.id): s.handle}) %}{% endfor %}

<div class="beacon-indexnow-widget">
    <div class="beacon-widget-stats">
        <div>
            <strong class="beacon-widget-stat__value beacon-widget-stat__value--lg">{{ counts.total|number }}</strong>
            <div class="light"><small>{{ 'widgets.indexNow.submissions.text'|t('beacon') }}</small></div>
        </div>
        <div>
            <strong class="beacon-widget-stat__value beacon-widget-stat__value--lg beacon-widget-stat__value--ok">{{ counts.ok|number }}</strong>
            <div class="light"><small>{{ 'widgets.indexNow.accepted.text'|t('beacon') }}</small></div>
        </div>
        <div>
            <strong class="beacon-widget-stat__value beacon-widget-stat__value--lg{{ counts.failed > 0 ? ' beacon-widget-stat__value--danger' : ' beacon-widget-stat__value--muted' }}">{{ counts.failed|number }}</strong>
            <div class="light"><small>{{ 'widgets.indexNow.rejected.text'|t('beacon') }}</small></div>
        </div>
    </div>

    {% if rows is empty %}
        <p class="light">{{ 'widgets.indexNow.no.indexnow.submissions.time.range.text'|t('beacon') }}</p>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ 'widgets.indexNow.message.text'|t('beacon') }}</th>
                    <th>{{ 'field.site'|t('beacon') }}</th>
                    <th>{{ 'widgets.indexNow.url.text'|t('beacon') }}</th>
                    <th>{{ 'widgets.indexNow.status.text'|t('beacon') }}</th>
                </tr>
            </thead>
            <tbody>
            {% for r in rows %}
                <tr>
                    <td>{{ r.submittedAt|datetime('short') }}</td>
                    <td><code>{{ siteHandles[r.siteId] ?? r.siteId }}</code></td>
                    <td>
                        {% if r.firstUrl %}<small><a href="{{ r.firstUrl }}" target="_blank" rel="noopener">{{ r.firstUrl|slice(0, 70) }}{% if r.firstUrl|length > 70 %}…{% endif %}</a></small>{% else %}<span class="light">—</span>{% endif %}
                        {% if r.urlCount > 1 %}<span class="light"> (+{{ r.urlCount - 1 }})</span>{% endif %}
                    </td>
                    <td>
                        {% if r.succeeded %}
                            <span class="beacon-status--ok">✓ {{ r.statusCode ?? 'widgets.indexNow.ok.text'|t('beacon') }}</span>
                        {% else %}
                            <span class="beacon-status--danger" title="{{ r.note ?? '' }}">✗ {{ r.statusCode ?? 'widgets.indexNow.err.text'|t('beacon') }}</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
