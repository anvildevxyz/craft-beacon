{# Dashboard widget body for GeoScoreWidget. Reads from beacon_geo_score only;
   no recompute happens here — saves on entries kick off async jobs. #}

{% if not hasScores %}
    <p class="light">
        {{ 'widgets.geoScore.no.geo.scores.yet.save.text'|t('beacon') }}
    </p>
{% else %}
    <ul class="bullets">
        <li>
            <strong>{{ average }}/100</strong>
            {{ 'widgets.geoScore.site.average.composite.text'|t('beacon') }}
            <span class="light">({{ distribution.total }} {{ 'widgets.geoScore.scored.entries.text'|t('beacon') }})</span>
        </li>
    </ul>

    {# Distribution histogram: 5 bands rendered as labeled bars proportional
       to share of total. Kept template-side (no JS) so it survives Cache. #}
    <hr>
    <h2 class="heading">{{ 'widgets.geoScore.distribution.heading'|t('beacon') }}</h2>
    <table class="data fullwidth beacon-geo-score-widget-distribution">
        <tbody>
            {% set bands = [
                { key: 'top',   label: 'widgets.geoScore.80.100.label'|t('beacon'),  cls: 'top' },
                { key: 'good',  label: 'widgets.geoScore.60.79.label'|t('beacon'),   cls: 'good' },
                { key: 'fair',  label: 'widgets.geoScore.40.59.label'|t('beacon'),   cls: 'fair' },
                { key: 'low',   label: 'widgets.geoScore.20.39.label'|t('beacon'),   cls: 'low' },
                { key: 'stale', label: 'widgets.geoScore.0.19.label'|t('beacon'),    cls: 'stale' },
            ] %}
            {% for band in bands %}
                {% set count = attribute(distribution, band.key) %}
                {% set pct = distribution.total > 0 ? (count / distribution.total * 100)|round : 0 %}
                <tr>
                    <th class="thin">{{ band.label }}</th>
                    <td>
                        <div class="beacon-geo-score-widget-bar beacon-geo-score-widget-bar--{{ band.cls }}" style="--beacon-bar-width: {{ pct }}%; --beacon-bar-min-width: {{ count > 0 ? '2%' : '0%' }};" aria-hidden="true"></div>
                    </td>
                    <td class="thin right"><strong>{{ count }}</strong> <span class="light">({{ pct }}%)</span></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if weakest %}
        <hr>
        <h2 class="heading">{{ 'widgets.geoScore.worst.scoring.entries.heading'|t('beacon') }}</h2>
        <p class="light">{{ 'widgets.geoScore.triage.these.first.weakest.pillar.text'|t('beacon') }}</p>
        <table class="data fullwidth beacon-geo-score-widget-entries">
            <thead>
                <tr>
                    <th>{{ 'widgets.geoScore.entry.text'|t('beacon') }}</th>
                    <th>{{ 'widgets.geoScore.weakest.pillar.text'|t('beacon') }}</th>
                    <th class="right">{{ 'widgets.geoScore.score.text'|t('beacon') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in weakest %}
                    {% set entry = craft.entries().id(row.elementId).siteId(row.siteId).status(null).one() %}
                    {% set editUrl = entry ? entry.cpEditUrl : null %}
                    <tr>
                        <td>
                            {% if editUrl %}
                                <a href="{{ editUrl }}">{{ row.title ?: ('widgets.geoScore.untitled.text'|t('beacon') ~ row.elementId) }}</a>
                            {% else %}
                                {{ row.title ?: ('widgets.geoScore.untitled.text'|t('beacon') ~ row.elementId) }}
                            {% endif %}
                            {% if row.url %}
                                <span class="light"><br><code>{{ row.url|replace({ 'https://': '', 'http://': '' }) }}</code></span>
                            {% endif %}
                        </td>
                        <td>
                            {% if row.weakestPillarLabel %}
                                {{ row.weakestPillarLabel }}
                                <span class="light">({{ row.weakestPillarScore }}/10)</span>
                            {% else %}
                                <span class="light">—</span>
                            {% endif %}
                        </td>
                        <td class="right"><strong>{{ row.score }}</strong>/100</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endif %}
