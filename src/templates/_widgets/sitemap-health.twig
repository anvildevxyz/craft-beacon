{% if not data.hasCache %}
    <p>{{ 'widgets.sitemapHealth.no.sitemap.has.been.generated.text'|t('beacon') }}</p>
{% else %}
    <div class="beacon-widget-stats">
        <div>
            <strong class="beacon-widget-stat__value">{{ data.totalUrls|number }}</strong>
            <div class="light"><small>{{ 'widgets.sitemapHealth.urls.cache.text'|t('beacon') }}</small></div>
        </div>
        <div>
            <strong>{{ data.mode == 'chunked' ? 'widgets.sitemapHealth.chunked.text'|t('beacon') : 'widgets.sitemapHealth.single.text'|t('beacon') }}</strong>
            {% if data.mode == 'chunked' %}
                <div class="light"><small>{{ 'widgets.sitemapHealth.parts.text'|t('beacon', { n: data.parts }) }}</small></div>
            {% endif %}
        </div>
        {% if data.lastRegen %}
            <div>
                <strong>{{ data.lastRegen|datetime('short') }}</strong>
                <div class="light"><small>{{ 'widgets.sitemapHealth.last.regenerated.text'|t('beacon') }}</small></div>
            </div>
        {% endif %}
    </div>

    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'widgets.sitemapHealth.chunk.text'|t('beacon') }}</th>
                <th>{{ 'widgets.sitemapHealth.urls.text'|t('beacon') }}</th>
                <th>{{ 'widgets.sitemapHealth.size.text'|t('beacon') }}</th>
                <th>{{ 'widgets.sitemapHealth.generated.text'|t('beacon') }}</th>
            </tr>
        </thead>
        <tbody>
        {% for c in data.chunks %}
            <tr>
                <td><code>{{ c.key }}</code></td>
                <td>{{ c.urls|number }}</td>
                <td>{{ (c.bytes / 1024)|number_format(1) }}{{ 'units.kilobytes'|t('beacon') }}</td>
                <td>{{ c.generatedAt ? c.generatedAt|datetime('short') : 'common.emDash'|t('beacon') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}
