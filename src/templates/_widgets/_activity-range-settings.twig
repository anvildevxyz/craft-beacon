{# Shared settings partial for bot / indexnow / redirect activity widgets.
   Each widget controller renders its own `*-activity-settings` template
   (path is part of Craft's widget contract), which delegates here so
   the time-range options stay in lockstep across the three widgets. #}
{% import '_includes/forms.twig' as forms %}

{{ forms.selectField({
    label: 'widgets.activityRange.range.label'|t('beacon'),
    name: 'range',
    value: widget.range,
    options: {
        '24h': 'widgets.activityRange.24.hours.text'|t('beacon'),
        '7d': 'widgets.activityRange.7.days.text'|t('beacon'),
        '30d': 'widgets.activityRange.30.days.text'|t('beacon'),
    },
    first: true,
}) }}
