{% set d = data %}

{% if not d.enabled %}
    <p class="light">{{ 'widgets.markdownCoverage.geo.markdown.disabled.enable.it.text'|t('beacon') }}</p>
{% else %}
    <ul class="bullets">
        <li>
            <strong>{{ d.coveragePercent }}%</strong>
            {{ 'widgets.markdownCoverage.coverage.text'|t('beacon') }}
            <span class="light">({{ d.totalGenerated }}/{{ d.totalEligible }} {{ 'widgets.markdownCoverage.elements.text'|t('beacon') }})</span>
        </li>
        <li>{{ 'widgets.markdownCoverage.queue.depth.text'|t('beacon') }}: <strong>{{ d.queueDepth }}</strong></li>
        {% if d.lastGenerated %}
            <li>{{ 'widgets.markdownCoverage.last.generated.text'|t('beacon') }}: <span class="light">{{ d.lastGenerated }}</span></li>
        {% endif %}
    </ul>

    {% if d.bySection %}
        <hr>
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ 'widgets.markdownCoverage.section.text'|t('beacon') }}</th>
                    <th class="right">{{ 'widgets.markdownCoverage.generated.text'|t('beacon') }}</th>
                    <th class="right">{{ 'widgets.markdownCoverage.total.text'|t('beacon') }}</th>
                    <th class="right">{{ 'widgets.markdownCoverage.message.text'|t('beacon') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in d.bySection %}
                    {% set pct = row.total > 0 ? (row.generated / row.total * 100)|round : 0 %}
                    <tr>
                        <td><code>{{ row.handle }}</code></td>
                        <td class="right">{{ row.generated }}</td>
                        <td class="right">{{ row.total }}</td>
                        <td class="right">{{ pct }}%</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endif %}
