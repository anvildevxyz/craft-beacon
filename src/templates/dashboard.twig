{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'dashboard' %}
{% set title = 'Beacon Dashboard'|t('beacon') %}

{% macro relativeTime(when) %}
    {%- if when is null -%}
        {{ '—'|t('beacon') }}
    {%- else -%}
        {%- set seconds = now.timestamp - when.timestamp -%}
        {%- if seconds < 60 -%}
            {{ 'just now'|t('beacon') }}
        {%- elseif seconds < 3600 -%}
            {{- (seconds // 60) ~ 'm ' ~ 'ago'|t('beacon') -}}
        {%- elseif seconds < 86400 -%}
            {{- (seconds // 3600) ~ 'h ' ~ 'ago'|t('beacon') -}}
        {%- elseif seconds < 2592000 -%}
            {{- (seconds // 86400) ~ 'd ' ~ 'ago'|t('beacon') -}}
        {%- else -%}
            {{- when|date('M j, Y') -}}
        {%- endif -%}
    {%- endif -%}
{% endmacro %}

{% macro bytesPretty(bytes) %}
    {%- if bytes < 1024 -%}
        {{ bytes ~ (' B'|t('beacon')) }}
    {%- elseif bytes < 1048576 -%}
        {{ (bytes / 1024)|number_format(1) ~ (' KB'|t('beacon')) }}
    {%- else -%}
        {{ (bytes / 1048576)|number_format(2) ~ (' MB'|t('beacon')) }}
    {%- endif -%}
{% endmacro %}

{% import _self as h %}

{% block content %}
    <div class="beacon-dash">

        <section>
            <h2 class="beacon-dash__eyebrow">{{ 'Status'|t('beacon') }}</h2>
            <div class="beacon-cards">

                <a href="{{ url('beacon/sitemap') }}" class="pane beacon-card">
                    <div class="beacon-card__head">
                        <span class="beacon-card__title">{{ 'Sitemap'|t('beacon') }}</span>
                        <span class="beacon-card__chevron" aria-hidden="true">›</span>
                    </div>
                    <div class="beacon-card__primary">
                        {% if sitemapCard.urlCount is not null %}
                            {{ sitemapCard.urlCount|number }}
                        {% elseif sitemapCard.enabled %}
                            ✓ {{ 'Active'|t('beacon') }}
                        {% else %}
                            {{ 'Inactive'|t('beacon') }}
                        {% endif %}
                    </div>
                    <div class="beacon-card__context">
                        {% if sitemapCard.enabled %}
                            {% if sitemapCard.urlCount is not null %}
                                <span class="beacon-card__ok">{{ 'URLs'|t('beacon') }}</span>
                            {% endif %}
                            {% if sitemapCard.lastGenerated %}
                                <span>{{ 'Generated'|t('beacon') }} {{ h.relativeTime(sitemapCard.lastGenerated) }}</span>
                            {% endif %}
                            {% if sitemapCard.urlCount is null and not sitemapCard.lastGenerated %}
                                <span>{{ 'Sections configured'|t('beacon') }}</span>
                            {% endif %}
                        {% else %}
                            <span>{{ 'No sections configured'|t('beacon') }}</span>
                        {% endif %}
                    </div>
                </a>

                <a href="{{ url('beacon/redirects') }}" class="pane beacon-card">
                    <div class="beacon-card__head">
                        <span class="beacon-card__title">{{ 'Redirects'|t('beacon') }}</span>
                        <span class="beacon-card__chevron" aria-hidden="true">›</span>
                    </div>
                    <div class="beacon-card__primary">{{ redirectsCard.active|number }}</div>
                    <div class="beacon-card__context">
                        {% if redirectsCard.active == 0 %}
                            <span>{{ 'No redirects yet'|t('beacon') }}</span>
                        {% else %}
                            {% if redirectsCard.stale > 0 %}
                                <span class="beacon-card__warn">⚠ {{ '{n} stale (90d+)'|t('beacon', { n: redirectsCard.stale }) }}</span>
                            {% else %}
                                <span>{{ 'All hit recently'|t('beacon') }}</span>
                            {% endif %}
                            {% if redirectsCard.lastHit %}
                                <span>{{ 'Last hit'|t('beacon') }} {{ h.relativeTime(redirectsCard.lastHit) }}</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </a>

                <a href="{{ url('beacon/tracking') }}" class="pane beacon-card">
                    <div class="beacon-card__head">
                        <span class="beacon-card__title">{{ 'Tracking'|t('beacon') }}</span>
                        <span class="beacon-card__chevron" aria-hidden="true">›</span>
                    </div>
                    {% if trackingCard.total == 0 %}
                        <div class="beacon-card__primary">{{ 'None'|t('beacon') }}</div>
                        <div class="beacon-card__context">
                            <span>{{ 'No tracking configured'|t('beacon') }}</span>
                        </div>
                    {% else %}
                        <div class="beacon-card__primary">{{ trackingCard.total|number }}</div>
                        <div class="beacon-card__context">
                            <span>{{ '{n,plural,=1{# script configured}other{# scripts configured}}'|t('beacon', { n: trackingCard.total }) }}</span>
                        </div>
                    {% endif %}
                </a>

                <div class="pane beacon-card beacon-card--readonly">
                    <div class="beacon-card__head">
                        <span class="beacon-card__title">{{ 'Breadcrumbs'|t('beacon') }}</span>
                    </div>
                    <div class="beacon-card__primary">
                        {% if breadcrumbsCard.enabled %}
                            ✓ {{ 'Enabled'|t('beacon') }}
                        {% else %}
                            {{ 'Disabled'|t('beacon') }}
                        {% endif %}
                    </div>
                    <div class="beacon-card__context">
                        {% if breadcrumbsCard.homeLabel and breadcrumbsCard.homeLabel != 'Home' %}
                            <span>{{ 'Label'|t('beacon') }}: {{ breadcrumbsCard.homeLabel|slice(0, 30) }}{{ breadcrumbsCard.homeLabel|length > 30 ? '…' }}</span>
                        {% endif %}
                        {% if breadcrumbsCard.totalSiteCount > 1 %}
                            <span>{{ '{n}/{total} sites enabled'|t('beacon', { n: breadcrumbsCard.enabledSiteCount, total: breadcrumbsCard.totalSiteCount }) }}</span>
                        {% endif %}
                    </div>
                </div>

            </div>
        </section>

        {% if setupChecklist|length %}
            <section class="pane beacon-dash__section">
                <h2 class="beacon-dash__eyebrow">{{ 'Setup checklist'|t('beacon') }}</h2>
                <ul class="beacon-feed">
                    {% for item in setupChecklist %}
                        <li class="beacon-feed__item">
                            <span class="beacon-feed__main">
                                <span class="beacon-feed__icon" aria-hidden="true">{{ item.done ? '✓' : '○' }}</span>
                                <span class="beacon-feed__text">{{ item.label }}</span>
                            </span>
                            <span class="beacon-feed__meta">
                                <a href="{{ url(item.url) }}">{{ item.done ? 'Configured'|t('beacon') : 'Configure'|t('beacon') }}</a>
                            </span>
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        <div class="beacon-grid">

            <section class="pane beacon-dash__section beacon-grid__feed">
                <h2 class="beacon-dash__eyebrow">{{ 'Recent activity'|t('beacon') }}</h2>
                <p class="light">
                    {{ 'Bot log'|t('beacon') }}: {{ botLogStats.rows|number }} {{ 'rows'|t('beacon') }},
                    {{ 'retention'|t('beacon') }} {{ botLogStats.retentionDays }}{{ 'd'|t('beacon') }},
                    {{ 'approx'|t('beacon') }} {{ h.bytesPretty(botLogStats.approxBytes) }},
                    {{ 'projected'|t('beacon') }} {{ h.bytesPretty(botLogStats.projectedBytes) }}
                </p>

                {% if activity is empty %}
                    <div class="beacon-feed__empty">
                        <p>{{ 'No activity yet — set up your first redirect or visit your site to record bot hits.'|t('beacon') }}</p>
                        <div class="beacon-feed__actions">
                            <a href="{{ url('beacon/redirects/new') }}">{{ '+ Add redirect'|t('beacon') }}</a>
                            <a href="{{ url('beacon/sitemap') }}">{{ 'Configure sitemap'|t('beacon') }}</a>
                        </div>
                    </div>
                {% else %}
                    <ul class="beacon-feed">
                        {% for event in activity %}
                            {% if event.type.value == 'redirect' %}
                                <li>
                                    <a href="{{ url('beacon/redirects/' ~ event.data.id) }}" class="beacon-feed__item">
                                        <span class="beacon-feed__main">
                                            <span class="beacon-feed__icon" aria-hidden="true">↪</span>
                                            <span class="beacon-feed__text">
                                                <code>{{ event.data.sourceUri }}</code>
                                                →
                                                <code>{{ event.data.targetUri }}</code>
                                            </span>
                                        </span>
                                        <span class="beacon-feed__meta">
                                            <span class="beacon-feed__status">{{ event.data.statusCode }}</span>
                                            <span>{{ h.relativeTime(event.when) }}</span>
                                        </span>
                                    </a>
                                </li>
                            {% elseif event.type.value == 'bot' %}
                                <li class="beacon-feed__item">
                                    <span class="beacon-feed__main">
                                        <span class="beacon-feed__icon" aria-hidden="true">🤖</span>
                                        <span class="beacon-feed__text">
                                            <strong>{{ event.data.botName }}</strong>
                                            {% if event.data.path %}
                                                {{ 'hit'|t('beacon') }} <code>{{ event.data.path }}</code>
                                            {% else %}
                                                {{ 'crawled'|t('beacon') }}
                                            {% endif %}
                                        </span>
                                    </span>
                                    <span class="beacon-feed__meta">
                                        <span>{{ h.relativeTime(event.when) }}</span>
                                    </span>
                                </li>
                            {% elseif event.type.value == 'schema' %}
                                <li>
                                    <a href="{{ url('beacon/schemas/' ~ event.data.id) }}" class="beacon-feed__item">
                                        <span class="beacon-feed__main">
                                            <span class="beacon-feed__icon" aria-hidden="true">🧩</span>
                                            <span class="beacon-feed__text">
                                                {{ 'Schema updated'|t('beacon') }}:
                                                <code>{{ event.data.entryTypeHandle }}</code>
                                                ({{ event.data.schemaType }})
                                            </span>
                                        </span>
                                        <span class="beacon-feed__meta">
                                            <span>{{ h.relativeTime(event.when) }}</span>
                                        </span>
                                    </a>
                                </li>
                            {% elseif event.type.value == 'sitemap' %}
                                <li class="beacon-feed__item">
                                    <span class="beacon-feed__main">
                                        <span class="beacon-feed__icon" aria-hidden="true">🗺</span>
                                        <span class="beacon-feed__text">{{ 'Sitemap regenerated'|t('beacon') }}</span>
                                    </span>
                                    <span class="beacon-feed__meta">
                                        <span>{{ h.relativeTime(event.when) }}</span>
                                    </span>
                                </li>
                            {% elseif event.type.value == 'llms' %}
                                <li class="beacon-feed__item">
                                    <span class="beacon-feed__main">
                                        <span class="beacon-feed__icon" aria-hidden="true">📄</span>
                                        <span class="beacon-feed__text">{{ 'llms.txt regenerated'|t('beacon') }}</span>
                                    </span>
                                    <span class="beacon-feed__meta">
                                        <span>{{ h.relativeTime(event.when) }}</span>
                                    </span>
                                </li>
                            {% elseif event.type.value == 'tracking' %}
                                <li>
                                    <a href="{{ url('beacon/tracking/' ~ event.data.uid) }}" class="beacon-feed__item">
                                        <span class="beacon-feed__main">
                                            <span class="beacon-feed__icon" aria-hidden="true">⚙</span>
                                            <span class="beacon-feed__text">
                                                {{ 'Tracking script changed'|t('beacon') }}:
                                                <strong>{{ event.data.name }}</strong>
                                            </span>
                                        </span>
                                        <span class="beacon-feed__meta">
                                            <span>{{ h.relativeTime(event.when) }}</span>
                                        </span>
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>

            <section class="pane beacon-dash__section beacon-grid__actions">
                <h2 class="beacon-dash__eyebrow">{{ 'Quick actions'|t('beacon') }}</h2>

                <div class="beacon-actions">
                    <a href="{{ url('beacon/redirects/new') }}" class="btn submit">
                        {{ '+ Add redirect'|t('beacon') }}
                    </a>

                    <form method="post">
                        {{ csrfInput() }}
                        <div class="beacon-actions">
                            <button type="submit" formaction="{{ actionUrl('beacon/maintenance/flush-cache') }}" class="btn">
                                <span class="beacon-actions__icon" aria-hidden="true">⟳</span>{{ 'Flush cache'|t('beacon') }}
                            </button>
                            <button type="submit" formaction="{{ actionUrl('beacon/maintenance/regenerate-sitemap') }}" class="btn">
                                <span class="beacon-actions__icon" aria-hidden="true">⚓</span>{{ 'Regenerate sitemap'|t('beacon') }}
                            </button>
                            <button type="submit" formaction="{{ actionUrl('beacon/maintenance/regenerate-llms-txt') }}" class="btn">
                                <span class="beacon-actions__icon" aria-hidden="true">📄</span>{{ 'Regenerate llms.txt'|t('beacon') }}
                            </button>
                            <button type="submit" formaction="{{ actionUrl('beacon/maintenance/regenerate-all') }}" class="btn">
                                <span class="beacon-actions__icon" aria-hidden="true">🔥</span>{{ 'Regenerate all'|t('beacon') }}
                            </button>
                        </div>
                    </form>
                </div>
            </section>

        </div>

    </div>
{% endblock %}
