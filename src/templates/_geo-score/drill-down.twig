{% extends '_layouts/cp' %}

{% set title = ('geoScore.drillDown.geo.score.text'|t('beacon', { title: element ? element.title : ('#' ~ elementId) })) %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: title },
] %}

{% block actionButton %}
    <div class="beacon-geo-score-drilldown__actions">
        <div class="btngroup">
            {% if element and element.cpEditUrl %}
                <a class="btn" href="{{ element.cpEditUrl }}">{{ 'geoScore.drillDown.open.entry.text'|t('beacon') }}</a>
            {% endif %}
            {% if canRecompute %}
                <button type="button"
                        class="btn submit"
                        data-beacon-recompute
                        data-element-id="{{ elementId }}"
                        data-site-id="{{ siteId }}">
                    {{ 'geoScore.drillDown.recompute.now.text'|t('beacon') }}
                </button>
            {% endif %}
        </div>
        {% if canRecompute %}
            <span class="beacon-geo-score-drilldown__status" data-beacon-recompute-status></span>
        {% endif %}
    </div>
{% endblock %}

{% block content %}
    <div class="beacon-dash beacon-geo-score-drilldown">
        <section class="pane beacon-geo-score-drilldown__pane">
            <div class="beacon-geo-score-drilldown__pane-head">
                <h2 class="heading">{{ 'geoScore.drillDown.composite.label'|t('beacon') }}</h2>
                <div class="beacon-geo-score-drilldown__meta">
                    <p><strong>{{ score.score }}/100</strong> {{ drillDown.compositeBandLabel }}</p>
                    {% if drillDown.weakest %}
                        <p class="light">{{ 'geoScore.drillDown.weakest.pillar.text'|t('beacon', { label: drillDown.weakest.label, score: drillDown.weakest.score }) }}</p>
                    {% endif %}
                    <p class="light">{{ 'geoScore.drillDown.computed.at.text'|t('beacon', { date: drillDown.computedAtFormatted }) }}</p>
                    {% if element and element.url %}
                        <p class="light"><code>{{ element.url|replace({ 'https://': '', 'http://': '' }) }}</code></p>
                    {% endif %}
                </div>
            </div>
        </section>

        {% if drillDown.focusPillars %}
            <section class="pane beacon-geo-score-drilldown__pane">
                <div class="beacon-geo-score-drilldown__pane-head">
                    <h2 class="heading">{{ 'geoScore.drillDown.focus.first.heading'|t('beacon') }}</h2>
                    <p class="light">{{ 'geoScore.drillDown.pillars.sorted.weakest.first.focus.text'|t('beacon') }}</p>
                </div>
                <table class="data fullwidth">
                    <thead>
                        <tr>
                            <th>{{ 'geoScore.drillDown.pillar.text'|t('beacon') }}</th>
                            <th class="thin">{{ 'geoScore.drillDown.score.text'|t('beacon') }}</th>
                            <th>{{ 'geoScore.drillDown.notes.text'|t('beacon') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in drillDown.focusPillars %}
                            {% set pillar = row.pillar %}
                            <tr>
                                <td>{{ pillar.label }}</td>
                                <td class="thin">
                                    <strong>{{ pillar.score }}</strong>/10
                                    <div class="beacon-geo-score-widget-bar beacon-geo-score-widget-bar--{{ pillar.band }}"
                                         style="--beacon-bar-width: {{ row.scorePct }}%; --beacon-bar-min-width: {{ pillar.score > 0 ? '2%' : '0%' }};"
                                         aria-hidden="true"></div>
                                </td>
                                <td>
                                    {% if row.notes %}
                                        <ul class="beacon-geo-score-drilldown__notes">
                                            {% for note in row.notes %}
                                                <li>
                                                    {{ note.text }}
                                                    {% if note.url and note.linkLabel %}
                                                        <a href="{{ note.url }}" class="go beacon-geo-score-drilldown__note-link">{{ note.linkLabel }}</a>
                                                    {% endif %}
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <span class="light">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        {% endif %}

        <section class="pane beacon-geo-score-drilldown__pane">
            <div class="beacon-geo-score-drilldown__pane-head">
                <h2 class="heading">{{ 'geoScore.drillDown.all.pillars.heading'|t('beacon') }}</h2>
                {% if drillDown.strongPillars %}
                    <p class="light">
                        {{ 'geoScore.drillDown.strong.pillars.summary'|t('beacon', { count: drillDown.strongPillars|length }) }}
                        {% for strong in drillDown.strongPillars %}
                            {{ strong.label }} ({{ strong.score }}/10){% if not loop.last %}, {% endif %}
                        {% endfor %}
                    </p>
                {% endif %}
            </div>
            <table class="data fullwidth beacon-geo-score-drilldown__pillars">
                <thead>
                    <tr>
                        <th>{{ 'geoScore.drillDown.pillar.text'|t('beacon') }}</th>
                        <th class="thin">{{ 'geoScore.drillDown.score.text'|t('beacon') }}</th>
                        <th>{{ 'geoScore.drillDown.notes.text'|t('beacon') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in drillDown.allPillars %}
                        {% set pillar = row.pillar %}
                        <tr>
                            <td>{{ pillar.label }}</td>
                            <td class="thin">
                                <strong>{{ pillar.score }}</strong>/10
                                <div class="beacon-geo-score-widget-bar beacon-geo-score-widget-bar--{{ pillar.band }}"
                                     style="--beacon-bar-width: {{ row.scorePct }}%; --beacon-bar-min-width: {{ pillar.score > 0 ? '2%' : '0%' }};"
                                     aria-hidden="true"></div>
                            </td>
                            <td>
                                {% if row.notes %}
                                    <ul class="beacon-geo-score-drilldown__notes">
                                        {% for note in row.notes %}
                                            <li>
                                                {{ note.text }}
                                                {% if note.url and note.linkLabel %}
                                                    <a href="{{ note.url }}" class="go beacon-geo-score-drilldown__note-link">{{ note.linkLabel }}</a>
                                                {% endif %}
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% else %}
                                    <span class="light">{{ 'geoScore.drillDown.no.actionable.feedback.pillar.top.text'|t('beacon') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>
{% endblock %}
