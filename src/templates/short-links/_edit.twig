{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'shortLinks' %}
{% import '_includes/forms.twig' as forms %}
{% set title = shortLink.id ? ('shortLinks.edit.edit.short.link.text'|t('beacon')) : ('shortLinks.edit.new.short.link.text'|t('beacon')) %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'nav.shortLinks'|t('beacon'), url: cpUrl('beacon/short-links') },
] %}

{% set statusOptions = [
    { value: 301, label: 'shortLinks.edit.301.moved.permanently.label'|t('beacon') },
    { value: 302, label: 'shortLinks.edit.302.found.temporary.label'|t('beacon') },
    { value: 307, label: 'shortLinks.edit.307.temporary.redirect.label'|t('beacon') },
    { value: 308, label: 'shortLinks.edit.308.permanent.redirect.label'|t('beacon') },
] %}

{% block content %}
	<input type="hidden" name="action" value="beacon/short-links/save">
	<input type="hidden" name="shortLinkId" value="{{ shortLink.id }}">
	<input type="hidden" name="siteId" value="{{ currentSite.id }}">
	{{ redirectInput('beacon/short-links') }}
	{{ csrfInput() }}

	{% if craft.app.isMultiSite %}
		<div class="field first">
			{{ forms.selectField({
            label: 'shortLinks.edit.propagationMethod.label'|t('beacon'),
            instructions: 'shortLinks.edit.propagationMethod.instructions'|t('beacon'),
            id: 'propagationMethod',
            name: 'propagationMethod',
            value: shortLink.propagationMethod.value ?? 'all',
            options: [
                { value: 'all', label: 'shortLinks.edit.all.sites.label'|t('beacon') },
                { value: 'siteGroup', label: 'shortLinks.edit.slug.label'|t('beacon') },
                { value: 'language', label: 'shortLinks.edit.slug.label.2'|t('beacon') },
                { value: 'none', label: 'shortLinks.edit.slug.label.3'|t('beacon') ~ ' (' ~ currentSite.name ~ ')' },
            ],
        }) }}
		</div>
	{% endif %}

	{{ forms.textField({
        label: 'shortLinks.edit.slug.label.4'|t('beacon'),
        instructions: 'shortLinks.edit.slug.instructions'|t('beacon'),
        id: 'slug',
        name: 'slug',
        value: shortLink.slug,
        required: true,
        errors: shortLink.getErrors('slug'),
    }) }}

	{{ forms.textField({
        label: 'shortLinks.edit.destination.label'|t('beacon'),
        instructions: 'shortLinks.edit.destination.instructions'|t('beacon'),
        id: 'destination',
        name: 'destination',
        value: shortLink.destination,
        required: true,
        errors: shortLink.getErrors('destination'),
    }) }}

	{{ forms.selectField({
        label: 'shortLinks.edit.statusCode.label'|t('beacon'),
        id: 'statusCode',
        name: 'statusCode',
        value: shortLink.statusCode,
        options: statusOptions,
    }) }}

	{{ forms.lightswitchField({
        label: 'field.enabled'|t('beacon'),
        id: 'enabled',
        name: 'enabled',
        on: shortLink.enabled,
    }) }}

	{{ forms.dateTimeField({
        label: 'shortLinks.edit.expiresAt.label'|t('beacon'),
        instructions: 'shortLinks.edit.expiresAt.instructions'|t('beacon'),
        id: 'expiresAt',
        name: 'expiresAt',
        value: shortLink.expiresAt,
    }) }}

	{{ forms.textareaField({
        label: 'shortLinks.edit.note.label'|t('beacon'),
        instructions: 'shortLinks.edit.note.instructions'|t('beacon'),
        id: 'note',
        name: 'note',
        value: shortLink.note,
        rows: 2,
        errors: shortLink.getErrors('note'),
    }) }}

	{% if shortLink.id %}
		<hr>
		<div class="beacon-shortlink-summary">
			<div>
				<p>
					<strong>{{ 'shortLinks.edit.short.url.text'|t('beacon') }}</strong>
				</p>
				<p>
					<a href="{{ siteUrl }}/{{ shortLink.slug }}" rel="noopener" target="_blank">
						<code>{{ siteUrl }}/{{ shortLink.slug }}</code>
					</a>
				</p>
				<p>
					<strong>{{ 'shortLinks.edit.clicks.text'|t('beacon') }}:</strong>
					{{ shortLink.clicks|number }}</p>
				<p>
					<strong>{{ 'shortLinks.edit.last.clicked.text'|t('beacon') }}:</strong>
					{{ shortLink.lastClicked ? shortLink.lastClicked|datetime('short') : ('common.emDash'|t('beacon')) }}</p>
			</div>
			<div class="beacon-shortlink-qr" id="beacon-shortlink-qr" data-url="{{ siteUrl }}/{{ shortLink.slug }}">
				<p class="light">
					<small>{{ 'shortLinks.edit.qr.preview.text'|t('beacon') }}</small>
				</p>
			</div>
		</div>

		{% do view.registerJsFile('https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js') %}
	{% endif %}
{% endblock %}
