{% extends "_layouts/cp" %}

{% set title = 'links.nav.broken.links'|t('beacon') %}
{% set selectedSubnavItem = 'links' %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'links.nav.overview'|t('beacon'), url: cpUrl('beacon/links') },
] %}

{% do view.registerAssetBundle('anvildev\\beacon\\web\\assets\\links\\LinksCpAsset') %}

{% block content %}
    <div class="beacon-links-toolbar">
        <a href="{{ url(craft.app.request.url, { format: 'csv' }) }}" class="btn">{{ 'links.report.export.csv'|t('beacon') }}</a>
    </div>

    {% if links|length %}
        <div class="beacon-links-card">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ 'links.report.source'|t('beacon') }}</th>
                        <th>{{ 'links.report.target.url'|t('beacon') }}</th>
                        <th>{{ 'links.report.status'|t('beacon') }}</th>
                        <th>{{ 'links.report.http.code'|t('beacon') }}</th>
                        <th>{{ 'links.report.last.checked'|t('beacon') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for link in links %}
                        <tr>
                            <td><a href="{{ link.sourceCpEditUrl }}"><strong>{{ link.sourceTitle }}</strong></a></td>
                            <td><code>{{ link.targetUrl }}</code></td>
                            <td>
                                {% if link.status == 'deleted' %}
                                    <span class="beacon-links-badge beacon-links-badge--error">{{ 'links.status.deleted'|t('beacon') }}</span>
                                {% elseif link.status == 'disabled' %}
                                    <span class="beacon-links-badge beacon-links-badge--warning">{{ 'links.status.disabled'|t('beacon') }}</span>
                                {% elseif link.status == 'http_error' %}
                                    <span class="beacon-links-badge beacon-links-badge--error">{{ 'links.status.http.error'|t('beacon') }}</span>
                                {% else %}
                                    <span class="beacon-links-badge">{{ link.status }}</span>
                                {% endif %}
                            </td>
                            <td>{{ link.httpStatus ?? '—' }}</td>
                            <td>{{ link.httpCheckedAt ?? '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="beacon-links-card">
            <div class="beacon-links-empty-state">
                <p class="beacon-links-empty-title">{{ 'links.report.broken.none.title'|t('beacon') }}</p>
                <p class="beacon-links-empty-text">{{ 'links.report.broken.none.text'|t('beacon') }}</p>
            </div>
        </div>
    {% endif %}
{% endblock %}
