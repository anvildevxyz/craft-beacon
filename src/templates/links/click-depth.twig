{% extends "_layouts/cp" %}

{% set title = 'links.nav.click.depth'|t('beacon') %}
{% set selectedSubnavItem = 'links' %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'links.nav.overview'|t('beacon'), url: cpUrl('beacon/links') },
] %}

{% do view.registerAssetBundle('anvildev\\beacon\\web\\assets\\links\\LinksCpAsset') %}

{% block content %}
    <div class="beacon-links-toolbar">
        <a href="{{ url(craft.app.request.url, { format: 'csv' }) }}" class="btn">{{ 'links.report.export.csv'|t('beacon') }}</a>
    </div>

    {% if entries|length %}
        <div class="beacon-links-card">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ 'links.report.title'|t('beacon') }}</th>
                        <th>{{ 'links.report.section'|t('beacon') }}</th>
                        <th>{{ 'links.report.depth'|t('beacon') }}</th>
                        <th>{{ 'links.report.inbound.links'|t('beacon') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in entries %}
                        <tr>
                            <td><a href="{{ entry.cpEditUrl }}"><strong>{{ entry.title }}</strong></a></td>
                            <td><span class="beacon-links-badge">{{ entry.sectionName }}</span></td>
                            <td>
                                {% if entry.depth >= 4 %}
                                    <span class="beacon-links-badge beacon-links-badge--warning">{{ entry.depth }}</span>
                                {% else %}
                                    {{ entry.depth }}
                                {% endif %}
                            </td>
                            <td>{{ entry.inboundCount }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="beacon-links-card">
            <div class="beacon-links-empty-state">
                <p class="beacon-links-empty-title">{{ 'links.report.clickdepth.none.title'|t('beacon') }}</p>
                <p class="beacon-links-empty-text">{{ 'links.report.clickdepth.none.text'|t('beacon') }}</p>
            </div>
        </div>
    {% endif %}

    {% if unreachable|length %}
        <h2>{{ 'links.report.unreachable'|t('beacon') }}</h2>
        <div class="beacon-links-card">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ 'links.report.title'|t('beacon') }}</th>
                        <th>{{ 'links.report.section'|t('beacon') }}</th>
                        <th>{{ 'links.report.inbound.links'|t('beacon') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in unreachable %}
                        <tr>
                            <td><a href="{{ entry.cpEditUrl }}"><strong>{{ entry.title }}</strong></a></td>
                            <td><span class="beacon-links-badge">{{ entry.sectionName }}</span></td>
                            <td>{{ entry.inboundCount }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
