{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'redirects' %}
{% import '_includes/forms.twig' as forms %}
{% set title = redirect.id ? ('redirects.edit.edit.redirect.text'|t('beacon')) : ('redirects.edit.new.redirect.text'|t('beacon')) %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'nav.redirects'|t('beacon'), url: cpUrl('beacon/redirects') },
] %}

{% block content %}
    <input type="hidden" name="action" value="beacon/redirects/save">
    <input type="hidden" name="redirectId" value="{{ redirect.id }}">
    <input type="hidden" name="siteId" value="{{ currentSite.id }}">
    {% if from404|default(0) > 0 %}
        <input type="hidden" name="from404" value="{{ from404 }}">
    {% endif %}
    {{ redirectInput('beacon/redirects') }}
    {{ csrfInput() }}

    {{ forms.lightswitchField({
        label: 'field.enabled'|t('beacon'),
        name: 'enabled',
        on: redirect.enabled ?? true,
        first: true,
    }) }}

    {% if craft.app.isMultiSite %}
        {{ forms.selectField({
            label: 'redirects.edit.propagationMethod.label'|t('beacon'),
            instructions: 'redirects.edit.propagationMethod.instructions'|t('beacon'),
            id: 'propagationMethod',
            name: 'propagationMethod',
            value: redirect.propagationMethod.value ?? 'all',
            options: [
                { value: 'all', label: 'redirects.edit.all.sites.label'|t('beacon') },
                { value: 'siteGroup', label: 'redirects.edit.sites.same.group.label'|t('beacon') },
                { value: 'language', label: 'redirects.edit.sourceUri.label'|t('beacon') },
                { value: 'none', label: 'redirects.edit.sourceUri.label.2'|t('beacon') ~ ' (' ~ currentSite.name ~ ')' },
            ],
        }) }}
    {% endif %}

    {{ forms.textField({
        label: 'redirects.edit.sourceUri.label.3'|t('beacon'),
        instructions: 'redirects.edit.sourceUri.instructions'|t('beacon'),
        name: 'sourceUri',
        value: redirect.sourceUri,
        required: true,
        errors: redirect.getErrors('sourceUri'),
    }) }}

    {{ forms.textField({
        label: 'redirects.edit.targetUri.label'|t('beacon'),
        instructions: 'redirects.edit.targetUri.instructions'|t('beacon'),
        name: 'targetUri',
        value: redirect.targetUri,
        required: true,
        errors: redirect.getErrors('targetUri'),
    }) }}

    {{ forms.selectField({
        label: 'redirects.edit.type.label'|t('beacon'),
        instructions: 'redirects.edit.type.instructions'|t('beacon'),
        name: 'type',
        value: redirect.type,
        options: {
            'exact': 'redirects.edit.exact.url.text'|t('beacon'),
            'glob': 'redirects.edit.wildcard.text'|t('beacon'),
            'regex': 'redirects.edit.pattern.advanced.text'|t('beacon'),
        },
    }) }}

    {{ forms.selectField({
        label: 'redirects.edit.statusCode.label'|t('beacon'),
        name: 'statusCode',
        value: redirect.statusCode,
        options: {
            '301': 'redirects.edit.301.permanent.text'|t('beacon'),
            '302': 'redirects.edit.302.temporary.text'|t('beacon'),
            '307': 'redirects.edit.307.temporary.preserve.method.text'|t('beacon'),
            '308': 'redirects.edit.308.permanent.preserve.method.text'|t('beacon'),
        },
    }) }}

    {{ forms.selectField({
        label: 'redirects.edit.queryStringMode.label'|t('beacon'),
        instructions: 'redirects.edit.queryStringMode.instructions'|t('beacon'),
        name: 'queryStringMode',
        value: redirect.queryStringMode ?? 'ignore',
        options: {
            'ignore': 'redirects.edit.ignore.path.only.text'|t('beacon'),
            'preserve': 'redirects.edit.preserve.append.target.text'|t('beacon'),
            'match': 'redirects.edit.match.source.includes.text'|t('beacon'),
        },
    }) }}

    {{ forms.textareaField({
        label: 'redirects.edit.note.label'|t('beacon'),
        instructions: 'redirects.edit.note.instructions'|t('beacon'),
        name: 'note',
        value: redirect.note,
        rows: 2,
        errors: redirect.getErrors('note'),
    }) }}

    {% if redirect.id %}
        <hr>
        <p><strong>{{ 'redirects.edit.hits.text'|t('beacon') }}:</strong> {{ redirect.hits|number }}</p>
        <p><strong>{{ 'redirects.edit.last.hit.text'|t('beacon') }}:</strong> {{ redirect.lastHit ? redirect.lastHit|datetime('short') : ('common.emDash'|t('beacon')) }}</p>
        <p><strong>{{ 'redirects.edit.origin.text'|t('beacon') }}:</strong> {{ redirect.source }}</p>
    {% endif %}
{% endblock %}
