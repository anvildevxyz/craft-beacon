{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'tracking' %}
{% import '_includes/forms.twig' as forms %}

{% set title = script.uid ? 'tracking.edit.edit.script.text'|t('beacon') : 'tracking.edit.new.script.text'|t('beacon') %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'tracking.edit.tracking.scripts.label'|t('beacon'), url: cpUrl('beacon/tracking') },
] %}
{% set fixed = provider.fixedPlacements %}

{% block content %}
    {{ csrfInput() }}
    {{ actionInput('beacon/tracking/save') }}
    {{ redirectInput('beacon/tracking') }}
    {% if script.uid %}{{ hiddenInput('uid', script.uid) }}{% endif %}
    {{ hiddenInput('provider', script.provider) }}

    {{ forms.textField({
        label: 'tracking.edit.name.label'|t('beacon'),
        id: 'name',
        name: 'name',
        value: script.name,
        required: true,
        errors: script.getErrors('name'),
        first: true,
    }) }}

    {{ forms.textField({
        label: 'tracking.edit.sortOrder.label'|t('beacon'),
        instructions: 'tracking.edit.sortOrder.instructions'|t('beacon'),
        id: 'sortOrder',
        name: 'sortOrder',
        value: script.sortOrder,
        type: 'number',
    }) }}

    {% set fieldsTemplate = provider.fieldsTemplate %}
    {% if fieldsTemplate %}
        <hr>
        <h2>{{ 'tracking.edit.configuration.heading'|t('beacon') }}</h2>
        {% include fieldsTemplate ignore missing with { script: script, provider: provider } %}
    {% endif %}

    {% if not fixed %}
        {{ forms.selectField({
            label: 'tracking.edit.placement.label'|t('beacon'),
            instructions: 'tracking.edit.placement.instructions'|t('beacon'),
            id: 'placement',
            name: 'placement',
            value: script.placement,
            options: [
                { label: 'tracking.edit.head.label'|t('beacon'), value: 'head' },
                { label: 'tracking.edit.body.start.label'|t('beacon'), value: 'bodyStart' },
                { label: 'tracking.edit.body.end.label'|t('beacon'), value: 'bodyEnd' },
            ],
        }) }}
    {% endif %}

    {% if sites|length > 1 %}
        <hr>
        <h2>{{ 'tracking.edit.per.site.overrides.heading'|t('beacon') }}</h2>
        <p class="light beacon-site-overrides__help">
            {{ 'tracking.edit.tick.site.disable.script.there.text'|t('beacon') }}
        </p>
        <div class="beacon-site-overrides__grid" role="group" aria-label="{{ 'tracking.edit.sites.disable.script.ariaLabel'|t('beacon') }}">
            {% for site in sites %}
                {% set ovr = script.siteOverrides[site.uid] ?? null %}
                <div class="beacon-site-overrides__item">
                    {{ forms.checkbox({
                        label: site.name,
                        name: 'siteOverrides[' ~ site.uid ~ '][enabled]',
                        value: '0',
                        checked: (ovr.enabled ?? null) is same as(false),
                    }) }}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
