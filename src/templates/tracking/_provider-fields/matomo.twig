{% import '_includes/forms.twig' as forms %}
{{ forms.textField({
    label: 'Matomo URL'|t('beacon'),
    name: 'config[matomoUrl]',
    value: script.config.matomoUrl ?? '',
    placeholder: 'https://matomo.example.com'|t('beacon'),
    required: true,
    errors: script.getErrors('config.matomoUrl'),
    first: true,
}) }}
{{ forms.textField({
    label: 'Site ID'|t('beacon'),
    name: 'config[siteId]',
    value: script.config.siteId ?? '',
    placeholder: '1'|t('beacon'),
    required: true,
    errors: script.getErrors('config.siteId'),
}) }}
