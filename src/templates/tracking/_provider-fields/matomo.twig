{% import '_includes/forms.twig' as forms %}
{{ forms.textField({
    label: 'tracking.matomo.config.matomoUrl..label'|t('beacon'),
    name: 'config[matomoUrl]',
    value: script.config.matomoUrl ?? '',
    placeholder: 'tracking.matomo.config.matomoUrl..placeholder'|t('beacon'),
    required: true,
    errors: script.getErrors('config.matomoUrl'),
    first: true,
}) }}
{{ forms.textField({
    label: 'tracking.matomo.config.siteId..label'|t('beacon'),
    name: 'config[siteId]',
    value: script.config.siteId ?? '',
    placeholder: 'tracking.matomo.config.siteId..placeholder'|t('beacon'),
    required: true,
    errors: script.getErrors('config.siteId'),
}) }}
