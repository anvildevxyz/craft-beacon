{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'crawlers' %}
{% import '_includes/forms.twig' as forms %}
{% set title = (rule ? 'aiCrawlers.rule.edit.title'|t('beacon') : 'aiCrawlers.rule.new.title'|t('beacon')) %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'nav.crawlers'|t('beacon'), url: cpUrl('beacon/crawlers/ai-crawlers') },
    { label: 'aiCrawlers.rule.ai.crawlers.label'|t('beacon'), url: cpUrl('beacon/crawlers/ai-crawlers') },
] %}

{% block content %}
    <input type="hidden" name="action" value="beacon/ai-crawlers/save-rule">
    {% if rule %}
        <input type="hidden" name="ruleId" value="{{ rule.id }}">
    {% endif %}
    {{ redirectInput('beacon/crawlers/ai-crawlers') }}
    {{ csrfInput() }}

    {{ forms.lightswitchField({
        label: 'field.enabled'|t('beacon'),
        name: 'enabled',
        on: rule ? rule.enabled : true,
        first: true,
    }) }}

    {{ forms.textField({
        label: 'aiCrawlers.rule.botName.label'|t('beacon'),
        instructions: 'aiCrawlers.rule.botName.instructions'|t('beacon'),
        name: 'botName',
        value: rule.botName|default(''),
        required: true,
    }) }}

    {{ forms.textareaField({
        label: 'aiCrawlers.rule.allowPaths.label'|t('beacon'),
        instructions: 'aiCrawlers.rule.allowPaths.instructions'|t('beacon'),
        name: 'allowPaths',
        value: rule.allowPaths|default([])|join('\n'),
        rows: 5,
        class: 'fontMono',
    }) }}

    {{ forms.textareaField({
        label: 'aiCrawlers.rule.disallowPaths.label'|t('beacon'),
        instructions: 'aiCrawlers.rule.disallowPaths.instructions'|t('beacon'),
        name: 'disallowPaths',
        value: rule.disallowPaths|default([])|join('\n'),
        rows: 5,
        class: 'fontMono',
    }) }}
{% endblock %}
