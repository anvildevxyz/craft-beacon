{% extends '_layouts/cp.twig' %}
{% set selectedSubnavItem = 'crawlers' %}
{% import '_includes/forms.twig' as forms %}
{% set title = (bot ? 'aiCrawlers.bot.edit.title'|t('beacon') : 'aiCrawlers.bot.new.title'|t('beacon')) %}
{% set fullPageForm = true %}
{% set crumbs = [
    { label: 'nav.beacon'|t('beacon'), url: cpUrl('beacon') },
    { label: 'nav.crawlers'|t('beacon'), url: cpUrl('beacon/crawlers/ai-crawlers') },
    { label: 'aiCrawlers.bot.ai.crawlers.label'|t('beacon'), url: cpUrl('beacon/crawlers/ai-crawlers') },
] %}

{% block content %}
    <input type="hidden" name="action" value="beacon/ai-crawlers/save-bot">
    {% if bot %}
        <input type="hidden" name="botId" value="{{ bot.id }}">
    {% endif %}
    {{ redirectInput('beacon/crawlers/ai-crawlers') }}
    {{ csrfInput() }}

    {{ forms.textField({
        label: 'aiCrawlers.bot.name.label'|t('beacon'),
        name: 'name',
        value: bot.name|default(''),
        required: true,
        first: true,
    }) }}

    {{ forms.textField({
        label: 'aiCrawlers.bot.userAgentPattern.label'|t('beacon'),
        instructions: 'aiCrawlers.bot.userAgentPattern.instructions'|t('beacon'),
        name: 'userAgentPattern',
        value: bot.userAgentPattern|default(''),
        required: true,
    }) }}

    {{ forms.lightswitchField({
        label: 'field.enabled'|t('beacon'),
        name: 'enabled',
        on: bot ? bot.enabled : true,
    }) }}

    {% if bot and bot.source == 'default' %}
        <p class="instructions"><strong>{{ 'aiCrawlers.bot.source.default.text'|t('beacon') }}</strong> {{ 'aiCrawlers.bot.bot.was.seeded.by.beacon.text'|t('beacon') }}</p>
    {% endif %}
{% endblock %}
